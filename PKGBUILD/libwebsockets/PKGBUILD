pkgname=libwebsockets
pkgver=4.5.8
pkgrel=1
pkgdesc="C library for websocket clients and servers"
arch=(armv6h)
url="https://libwebsockets.org"
license=(MIT)
depends=(glibc openssl libuv libev zlib)
makedepends=(cmake glib2 libcap)

source=($pkgname-$pkgver.tar.gz::https://github.com/warmcat/$pkgname/archive/v$pkgver.tar.gz)
sha512sums=('77fcb15c325d514fee18193a6509755618ce4232115259377d67f93015490a11642f5974fddd2efebc89496e28a52f0a135b6635c662be1e2c641aaa68397b11')

build() {
  # Clean up host-specific flags
  unset CFLAGS CXXFLAGS LDFLAGS

  local _sysroot="/home/x/x-sysroot"
  local _toolchain_path="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf"

cat > toolchain.cmake <<-EOF
	set(CMAKE_SYSTEM_NAME Linux)
	set(CMAKE_SYSTEM_PROCESSOR arm)
	# Force CMake to recognize this as a cross-compile so it stops trying to run tests
	set(CMAKE_CROSSCOMPILING TRUE)
	
	set(CMAKE_C_COMPILER ${_toolchain_path}-gcc)
	set(CMAKE_CXX_COMPILER ${_toolchain_path}-g++)
	set(CMAKE_SYSROOT ${_sysroot})
	set(CMAKE_FIND_ROOT_PATH ${_sysroot})
	
	# Point QEMU to the sysroot if it must run
	set(CMAKE_EXECUTABLE_SUFFIX "")
	set(CMAKE_CROSSCOMPILING_EMULATOR /usr/bin/qemu-arm-static -L ${_sysroot})
	
	set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
	set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
	set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
	EOF
  cmake -B build -S $pkgname-$pkgver \
        -DCMAKE_TOOLCHAIN_FILE="${PWD}/toolchain.cmake" \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DLWS_WITH_STATIC=OFF \
        -DLWS_WITH_LIBUV=ON \
        -DLWS_WITH_LIBEV=ON \
        -DLWS_WITH_GLIB=ON \
        -DLWS_WITH_HTTP2=ON \
        -DLWS_WITHOUT_TESTAPPS=ON \
        -DOPENSSL_ROOT_DIR="${_sysroot}/usr" \
        -DZLIB_INCLUDE_DIR="${_sysroot}/usr/include" \
        -DZLIB_LIBRARY="${_sysroot}/usr/lib/libz.so"

  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -vDm 644 $pkgname-$pkgver/LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
}