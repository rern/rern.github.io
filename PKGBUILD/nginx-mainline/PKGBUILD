_pkgbase=nginx
pkgbase=nginx-mainline
pkgname=(
  nginx-mainline
  nginx-mainline-mod-geoip
  nginx-mainline-mod-image-filter
  nginx-mainline-mod-mail
  nginx-mainline-mod-perl
  nginx-mainline-mod-stream
  nginx-mainline-mod-xslt
  nginx-mainline-src
)
