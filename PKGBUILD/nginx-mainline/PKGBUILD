pkgrel=1
_tests_commit=4d1de3f357afeb91865d024b27516d6b67aad86e
arch=('armv6h')
pkgdesc='Lightweight HTTP server and IMAP/POP3 proxy server, mainline release (Cross-compiled)'
url='https://nginx.org'
license=('BSD-2-Clause')
options=('!docs')
