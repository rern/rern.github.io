pkgname=libsasl
pkgver=2.1.28
pkgrel=5
pkgdesc="Cyrus Simple Authentication Service Layer (SASL) library"
arch=(armv6h)
url="https://www.cyrusimap.org/sasl/"
license=(BSD-3-Clause-Attribution)
depends=(glibc gdbm libgdbm.so openssl libcrypto.so)
makedepends=(git autoconf automake libtool mariadb-libs postgresql-libs sqlite)
provides=(libsasl2.so)

_name=cyrus-sasl
_url=https://github.com/cyrusimap/cyrus-sasl
source=($_name::git+$_url.git?signed#tag=$_name-$pkgver)

_sysroot="/home/x/x-sysroot"
_toolchain_bin="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
_cross_host="armv6-rpi-linux-gnueabihf"

prepare() {
  cd $_name
  
  # 1. Purge all potentially contaminating environment variables
  unset CC CXX CPP LD AR NM RANLIB CFLAGS CXXFLAGS LDFLAGS
  
  # 2. Set strict cross-compilation environment
  export PATH="${_toolchain_bin}:${PATH}"
  export CC="${_cross_host}-gcc --sysroot=${_sysroot}"
  export CXX="${_cross_host}-g++ --sysroot=${_sysroot}"
  
  # 3. Force the GSSAPI SPNEGO result to 'no' via environment variable
  # This tricks the configure script into skipping the AC_RUN_IFELSE block.
  export ac_cv_gssapi_supports_spnego=no
  
  # 4. Regenerate with clean environment
  ACLOCAL_PATH="" autoreconf -fiv
  
  # 5. Configure with explicit overrides
  ./configure --prefix=/usr \
              --host="${_cross_host}" \
              --build="x86_64-pc-linux-gnu" \
              --without-gssapi \
              --disable-static \
              --enable-shared \
              --with-dblib=gdbm \
              --with-configdir=/etc/sasl2 \
              ac_cv_func_malloc_0_nonnull=yes \
              ac_cv_func_realloc_0_nonnull=yes \
              ac_cv_func_strchr=yes \
              ac_cv_func_getaddrinfo=yes \
              ac_cv_prog_cc_c23=no
  
  # 6. Sanitize libtool to prevent host path leakage
  sed -i 's/-L\/usr\/lib//g' libtool
  sed -i 's/relink_command=".*"/relink_command=""/' libtool
}

build() {
  export PATH="${_toolchain_bin}:${PATH}"
  cd $_name
  
  # 1. Use -std=gnu89 to handle the K&R/ANSI macro mess in md5.c
  # 2. Use -Wno-error to ignore the "old-style function definition" warnings
  # 3. Use -fgnu89-inline to fix potential symbol linkage issues
  make CFLAGS="-O2 -std=gnu89 -Wno-error -fgnu89-inline"
}

package() {
  cd $_name
  make DESTDIR="$pkgdir" install
  rm -fv "$pkgdir"/usr/lib/sasl2/lib{gs2,gssapiv2,ldapdb,sql}.so*
  install -vDm 644 COPYING -t "$pkgdir/usr/share/licenses/$pkgname/"
}