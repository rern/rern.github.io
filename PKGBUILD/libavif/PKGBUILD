# Maintainer: Adapted for cross-compilation

# ALARM: Kevin Mihelich <kevin@archlinuxarm.org>
#  - remove depends on svt-av1
#  - set -DAVIF_CODEC_SVT=OFF
#  - remove makedepends on pandoc-cli, set -DAVIF_BUILD_MAN_PAGES=OFF

pkgname=libavif
pkgver=1.4.2
pkgrel=1
_libargparse=ee74d1b53bd680748af14e737378de57e2a0a954
pkgdesc="Library for encoding and decoding .avif files"
arch=(armv6h)
url="https://github.com/AOMediaCodec/libavif"
license=(LicenseRef-libavif)
depends=(aom
         dav1d
         glibc
         libgcc
         libjpeg-turbo
         libpng
         libstdc++
         libwebp
         libxml2
         libyuv
         rav1e)
makedepends=(cmake git nasm)
source=(git+https://github.com/AOMediaCodec/libavif#tag=v$pkgver
        git+https://github.com/kmurray/libargparse#commit=$_libargparse)
sha256sums=('2c84afde7ea25afbf3ed9981d65a87723920137e1033f5e4fb48c76c4566ede1'
            '235020da02227503eb09961efd664aca6e544a8b3ed5533cf81e1862bb94f48f')

prepare() {
  cp -r libargparse libavif/ext
  # Ensure modern CMake minimum version is declared
  sed -i '1i cmake_minimum_required(VERSION 3.5)' libavif/CMakeLists.txt
}

build() {
  # Clear host defaults that break cross builds
  unset CPPFLAGS
  unset CFLAGS
  unset CXXFLAGS
  unset LDFLAGS

  # Set ARMv6‑safe flags
  export CFLAGS="-march=armv6 -mfpu=vfp -mfloat-abi=hard -O2"
  export CXXFLAGS="$CFLAGS"
  export LDFLAGS=""

  # Cross toolchain
  export CC="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-gcc"
  export CXX="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-g++"
  export AR="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-ar"
  export RANLIB="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-ranlib"

  export PKG_CONFIG_SYSROOT_DIR="/home/x/x-sysroot"
  export PKG_CONFIG_PATH="/home/x/x-sysroot/usr/lib/pkgconfig:/home/x/x-sysroot/usr/share/pkgconfig"

  # Toolchain file
  cat > "${srcdir}/armv6h.cmake" <<EOF
  set(CMAKE_SYSTEM_NAME Linux)
  set(CMAKE_SYSTEM_PROCESSOR arm)
  set(CMAKE_SYSROOT /home/x/x-sysroot)

  set(CMAKE_C_COMPILER ${CC})
  set(CMAKE_CXX_COMPILER ${CXX})
  set(CMAKE_AR ${AR})
  set(CMAKE_RANLIB ${RANLIB})

  # Force ARM flags, override host defaults
  set(CMAKE_C_FLAGS "-march=armv6 -mfpu=vfp -mfloat-abi=hard -O2" CACHE STRING "" FORCE)
  set(CMAKE_CXX_FLAGS "-march=armv6 -mfpu=vfp -mfloat-abi=hard -O2" CACHE STRING "" FORCE)

  set(CMAKE_FIND_ROOT_PATH /home/x/x-sysroot)
  set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
  set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
  set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
  set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
EOF

  cmake -B build -S $pkgname \
    -DCMAKE_TOOLCHAIN_FILE="${srcdir}/armv6h.cmake" \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DAVIF_BUILD_APPS=ON \
    -DAVIF_BUILD_MAN_PAGES=OFF \
    -DAVIF_CODEC_AOM=OFF \
    -DAVIF_CODEC_DAV1D=SYSTEM \
    -DAVIF_CODEC_RAV1E=SYSTEM \
    -DAVIF_CODEC_SVT=OFF \
    -DAVIF_LIBSHARPYUV=SYSTEM \
    -DAVIF_LIBXML2=SYSTEM \
    -DAVIF_BUILD_GDK_PIXBUF=OFF

  make -C build
}

package() {
  make -C build DESTDIR="$pkgdir" install
  install -Dm644 $pkgname/LICENSE -t "${pkgdir}"/usr/share/licenses/$pkgname
}
