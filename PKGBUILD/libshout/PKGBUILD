pkgname=libshout
pkgver=2.4.6
pkgrel=5
epoch=1
pkgdesc="Library for accessing a shoutcast/icecast server"
arch=('armv6h')
url="https://www.icecast.org/"
license=('LGPL')
depends=('libvorbis' 'libtheora' 'speex' 'openssl')
makedepends=('git')

source=("icecast-libshout::git+https://gitlab.xiph.org/xiph/icecast-libshout.git#tag=v${pkgver}"
        "git+https://gitlab.xiph.org/xiph/icecast-common.git"
        "git+https://gitlab.xiph.org/xiph/icecast-m4.git")
sha512sums=('SKIP' 'SKIP' 'SKIP')

prepare() {
  cd icecast-libshout
  
  # Configure git submodules to use local sources
  git submodule init
  git config submodule.m4.url "${srcdir}/icecast-m4"
  git config submodule.src/common.url "${srcdir}/icecast-common"
  git -c protocol.file.allow=always submodule update
  
  autoreconf -fiv
}

build() {
  cd icecast-libshout

  local _sysroot="/home/x/x-sysroot"
  local _toolchain_path="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf"

  # Toolchain exports
  export CC="${_toolchain_path}-gcc"
  export CXX="${_toolchain_path}-g++"
  export AR="${_toolchain_path}-ar"
  export RANLIB="${_toolchain_path}-ranlib"
  
  # Crucial: restrict pkg-config to sysroot
  export PKG_CONFIG_DIR=""
  export PKG_CONFIG_LIBDIR="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"
  export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"

  # Set sysroot flags
  export CFLAGS="--sysroot=${_sysroot} -O2"
  export LDFLAGS="--sysroot=${_sysroot} -L${_sysroot}/usr/lib"

  ./configure \
    --host=armv6l-unknown-linux-gnueabihf \
    --build=x86_64-pc-linux-gnu \
    --prefix=/usr \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --with-openssl="${_sysroot}/usr"

  make
}

package() {
  cd icecast-libshout
  make DESTDIR="${pkgdir}" install
}