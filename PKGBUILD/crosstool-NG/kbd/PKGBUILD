pkgname=kbd
pkgver=2.10.0
pkgrel=1
pkgdesc="Keytable files and keyboard utilities (Cross-compiled for armv6h)"
arch=('armv6h')
url="http://www.kbd-project.org"
license=('GPL-2.0-or-later')
depends=(
  glibc
  gzip
  pam
)
makedepends=(
  check
  git
)
source=(
  git+https://git.kernel.org/pub/scm/linux/kernel/git/legion/kbd.git?signed#tag=v$pkgver
  fix-euro2.patch
  vlock.pam
)
backup=('etc/pam.d/vlock')
provides=('vlock')
conflicts=('vlock')
replaces=('vlock')
b2sums=('e98958b6bd29c1ffe9a22ad2e466db50edebf6f8fbe403b59e70f3a5c44adc11e3948d43a59859b13558107bcc1e63153be2b784bcd8616268fb08bf3f3a5e1d'
        'd122ddb1a86e7a282df8e438903f94d697e3d18a24154d976334e6b54b8f1cf1df432cf8dbcd98daa55014ada462f284d0319fbf015554266e91f4d2a8bf812b'
        '104543e72331a633572a26059e6dce1f25c3c8d6deabb855dd94bfffb72edf8a53a58c6ea7ef6806dd80bcd6ab0aa47cc1a45cc0cd90330be6514ff7591b5140')
validpgpkeys=(
  '7F2A3D07298149A0793C9A4EA45ABA544CFFD434'
)

prepare() {
  cd "${pkgname}"
  mv data/keymaps/i386/qwertz/cz{,-qwertz}.map
  mv data/keymaps/i386/olpc/es{,-olpc}.map
  mv data/keymaps/i386/olpc/pt{,-olpc}.map
  mv data/keymaps/i386/fgGIod/trf{,-fgGIod}.map
  mv data/keymaps/i386/colemak/{en-latin9,colemak}.map
  patch -Np1 -i ../fix-euro2.patch
  
  # 1. Strip the target function call inside loadkeys to skip runtime compilation logic dependencies
  sed -i 's/rc = convert_xkb_keymap(ctx, \&xkeymap_params);/rc = 0; \/\/ XKB disabled/g' src/loadkeys.c

  # 2. Completely remove xkbsupport files from the Autotools file compilation tree
  sed -i 's/xkbsupport.c//g' src/Makefile.am
  sed -i 's/xkbsupport.h//g' src/Makefile.am

  autoreconf -if
}

build() {
  TOOLCHAIN="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
  SYSROOT="/home/x/x-sysroot"

  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS CHOST

  local TARGET_CC="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-gcc"
  local TARGET_CXX="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-g++"
  local TARGET_AR="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ar"
  local TARGET_RANLIB="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ranlib"
  local TARGET_LD="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ld"

  local TARGET_CFLAGS="--sysroot=${SYSROOT} -O2 -D_GNU_SOURCE -DO_BINARY=0 -DO_TEXT=0 -Dstrlcpy=strncpy -Dstrlcat=strncat"
  local TARGET_CXXFLAGS="--sysroot=${SYSROOT} -O2"
  local TARGET_CPPFLAGS="--sysroot=${SYSROOT}"
  local TARGET_LDFLAGS="--sysroot=${SYSROOT} -L${SYSROOT}/usr/lib"

  cd "${pkgname}"
  
  # LIBS="-ldl" passes execution symbols safely to drop elf-note symbol linkage errors
  ./configure --host=armv6-rpi-linux-gnueabihf \
              --build=$(gcc -dumpmachine) \
              --prefix=/usr \
              --sysconfdir=/etc \
              --datadir=/usr/share/kbd \
              --mandir=/usr/share/man \
              --enable-optional-progs \
              --disable-tests \
              --disable-vlock \
              LIBS="-ldl" \
              CC="${TARGET_CC}" \
              CXX="${TARGET_CXX}" \
              AR="${TARGET_AR}" \
              RANLIB="${TARGET_RANLIB}" \
              LD="${TARGET_LD}" \
              CFLAGS="${TARGET_CFLAGS}" \
              CXXFLAGS="${TARGET_CXXFLAGS}" \
              CPPFLAGS="${TARGET_CPPFLAGS}" \
              LDFLAGS="${TARGET_LDFLAGS}"
              
  make KEYCODES_PROGS=yes RESIZECONS_PROGS=yes MALLOC_0_IS_NONNULL=1
}

package() {
  cd "${pkgname}"
  make KEYCODES_PROGS=yes RESIZECONS_PROGS=yes DESTDIR="${pkgdir}" install
  
  if [ -f ../vlock.pam ] && [ -d "${pkgdir}"/etc/pam.d ]; then
    install -Dm644 ../vlock.pam "${pkgdir}"/etc/pam.d/vlock
  fi
}