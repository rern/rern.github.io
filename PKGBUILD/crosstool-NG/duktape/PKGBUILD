pkgname=duktape
pkgver=2.7.0
pkgrel=7
pkgdesc='Embeddable Javascript engine'
url='https://duktape.org/'
arch=(armv6h)
license=(MIT)
depends=(glibc)
source=("https://duktape.org/duktape-$pkgver.tar.xz")

prepare() {
  cd duktape-$pkgver
  sed -i 's/^#undef DUK_USE_FASTINT$/#define DUK_USE_FASTINT/' src/duk_config.h
  sed -i 's/duktape\.c/& -lm/' Makefile.sharedlibrary
}

_make() {
  local TOOLCHAIN_PATH="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-"
  local SYSROOT="/home/x/x-sysroot"

  make -f Makefile.sharedlibrary \
    INSTALL_PREFIX=/usr \
    CC="${TOOLCHAIN_PATH}gcc" \
    LD="${TOOLCHAIN_PATH}gcc" \
    AR="${TOOLCHAIN_PATH}ar" \
    RANLIB="${TOOLCHAIN_PATH}ranlib" \
    CFLAGS="--sysroot=$SYSROOT -O2 -pipe" \
    LDFLAGS="--sysroot=$SYSROOT" \
    "$@"
}

build() {
  cd duktape-$pkgver
  _make
}

package() {
  cd duktape-$pkgver
  _make DESTDIR="$pkgdir" install
  install -Dt "$pkgdir/usr/share/licenses/$pkgname" -m644 LICENSE.txt
}