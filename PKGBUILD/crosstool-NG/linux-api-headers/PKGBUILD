# Maintainer: You

pkgname=linux-api-headers
pkgver=7.1
pkgrel=1
pkgdesc='Kernel headers sanitized for use in ARMv6h userspace'
arch=('armv6h')
url='https://www.gnu.org/software/libc'
license=(GPL-2.0-only)
makedepends=(rsync)
source=(https://www.kernel.org/pub/linux/kernel/v${pkgver:0:1}.x/linux-${pkgver}.tar.{xz,sign})
sha256sums=('691f44797fbe790dc8a321604c927087526ad27b6d649925d60f8eed0a2564a0'
            'SKIP')
validpgpkeys=(
  'ABAF11C65A2970B130ABE3C479BE3E4300411886'   # Linus Torvalds
  '647F28654894E3BD457199BE38DBBDC86092693E'  # Greg Kroah-Hartman
)

prepare() {
  cd linux-$pkgver
  make mrproper
}

build() {
  cd linux-$pkgver
  # Nothing to build, just sanitize headers
}

package() {
  cd linux-$pkgver

  SYSROOT=/home/x/rpi0_sysroot

  # Install headers into package dir
  make ARCH=arm INSTALL_HDR_PATH="$pkgdir/usr" headers_install

  # Optionally sync into your cross sysroot
  mkdir -p "$SYSROOT/usr/include"
  rsync -av "$pkgdir/usr/include/" "$SYSROOT/usr/include/"
}
