# Maintainer: Evgeniy Alekseev <arcanis at archlinux dot org>
pkgname=jq
pkgver=1.8.2
pkgrel=1
pkgdesc='Command-line JSON processor'
arch=(armv6h)
url='https://jqlang.github.io/jq/'
license=('MIT')
depends=('glibc' 'oniguruma')
makedepends=('autoconf' 'automake' 'bison' 'flex' 'git')

source=("git+https://github.com/jqlang/jq.git#tag=jq-${pkgver}")
sha512sums=('SKIP')

build() {
  cd "$pkgname"
  
  # 1. Clean environment
  unset CFLAGS CXXFLAGS LDFLAGS

  # 2. Prepare the build system
  autoreconf -fi

  # 3. Configure to use the sysroot library
  # We define the sysroot path so the linker finds the ARM version of oniguruma
  ./configure \
    --host=armv6l-unknown-linux-gnueabihf \
    --prefix=/usr \
    --with-oniguruma=yes \
    CC='/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-gcc' \
    LD='/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-ld' \
    CFLAGS="--sysroot=/home/x/x-sysroot -I/home/x/x-sysroot/usr/include" \
    LDFLAGS="--sysroot=/home/x/x-sysroot -L/home/x/x-sysroot/usr/lib"

  make
}
check() {
  echo "Skipping tests for cross-compilation."
}

package() {
  cd "$pkgname"
  make DESTDIR="${pkgdir}" install
  install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}