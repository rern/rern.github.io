# Maintainer: David Runge <dvzrv@archlinux.org>

pkgbase=elfutils
pkgname=(
  elfutils
  libelf
)
pkgver=0.195
pkgrel=1
pkgdesc="Handle ELF object files and DWARF debugging information (Cross-compiled for armv6h)"
arch=(armv6h)
url="https://sourceware.org/elfutils/"
_url=https://sourceware.org/git/elfutils.git
makedepends=(
  bzip2
  curl
  git
  json-c
  libarchive
  libgcc
  libstdc++
  xz
  zlib
  zstd
)
options=(staticlibs)
source=(git+$_url?signed#tag=$pkgbase-$pkgver
        "remove-comment.patch")
sha512sums=('7bbc1db55939e999683ccff41f287433ed926e255b4a35048812bc85505a1b3339828691691c769c4d79347f513792356c2d6b1727eabe0fd720722f7076643e'
            'e33fe8d3fc9347fc9839c3958e51f8dbb7fbe4670b44ede503f5e8237998c80c4d53dfb7a6f36bc33d552ee35aaa955f7323a60476f315afd4fbee052a6551a1')
b2sums=('6be17af5c5d015e028f1658f63a5a635c00952c98fa76be4f5a56c27366681a56f8e288261db876c51bc884a8a3fc4d03ecdf965e0e0fc98a2ebb3d4351d2d1c'
        'c48aba30e2890744700982a49fef69bae94e1db0036fb25c0168c18ebbe8baf2f7ab49e46c384506ef7d35d4bebb028241112103f2be474c717f292d9a4c003b')
validpgpkeys=(
  'EC3CFE88F6CA0788774F5C1D1AA44BE649DE760A'  # Mark Wielaard <mjw@gnu.org>
  '6C2B631563B8D330578D3CB474FD3FA2779E7073'  # Aaron Merey <amerey@redhat.com>
)

prepare() {
  cd $pkgbase
  git cherry-pick -n 00cb3efe36337f27925dbff9b2e7d97c7df95bf8
  git cherry-pick -n 4a5cf8be906d5991e7527e69e3f2ceaa74811301

  sed -e 's/run-backtrace-native.sh//g' -i tests/Makefile.am

  patch -Np1 < "$srcdir/remove-comment.patch"

  autoreconf -fiv
}

build() {
  TOOLCHAIN="/home/x/x-tools/armv6-rpi-linux-gnueabihf"
  SYSROOT="/home/x/x-sysroot"

  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS CHOST

  export QEMU_LD_PREFIX="${SYSROOT}"

  local TARGET_CC="${TOOLCHAIN}/bin/armv6-rpi-linux-gnueabihf-gcc"
  local TARGET_CXX="${TOOLCHAIN}/bin/armv6-rpi-linux-gnueabihf-g++"
  local TARGET_AR="${TOOLCHAIN}/bin/armv6-rpi-linux-gnueabihf-ar"
  local TARGET_RANLIB="${TOOLCHAIN}/bin/armv6-rpi-linux-gnueabihf-ranlib"
  local TARGET_LD="${TOOLCHAIN}/bin/armv6-rpi-linux-gnueabihf-ld"

  local TARGET_CFLAGS="--sysroot=${SYSROOT} -O2 -D_GNU_SOURCE -ffat-lto-objects -g"
  local TARGET_CXXFLAGS="--sysroot=${SYSROOT} -O2 -ffat-lto-objects -g"
  local TARGET_CPPFLAGS="--sysroot=${SYSROOT} -I${SYSROOT}/usr/include"
  
  # Standardized standard sysroot linker target mappings
  local TARGET_LDFLAGS="--sysroot=${SYSROOT} -L${SYSROOT}/usr/lib -L${SYSROOT}/lib -Wl,-rpath-link,${SYSROOT}/usr/lib:${SYSROOT}/lib"

  export PKG_CONFIG_SYSROOT_DIR="${SYSROOT}"
  export PKG_CONFIG_LIBDIR="${SYSROOT}/usr/lib/pkgconfig:${SYSROOT}/usr/share/pkgconfig"

  local configure_options=(
    --host=armv6-rpi-linux-gnueabihf
    --build=$(gcc -dumpmachine)
    --prefix=/usr
    --sysconfdir=/etc
    --program-prefix="eu-"
    --enable-deterministic-archives
    --enable-maintainer-mode
    --disable-static
    --with-zlib
    --with-bzlib
    --with-lzma
    --with-zstd
    # Explicitly turn off the C++ telemetry tools to bypass runtime version anomalies
    --disable-debuginfod
    --disable-libdebuginfod
  )

  cd $pkgbase
  ./configure "${configure_options[@]}" \
              CC="${TARGET_CC}" \
              CXX="${TARGET_CXX}" \
              AR="${TARGET_AR}" \
              RANLIB="${TARGET_RANLIB}" \
              LD="${TARGET_LD}" \
              CFLAGS="${TARGET_CFLAGS}" \
              CXXFLAGS="${TARGET_CXXFLAGS}" \
              CPPFLAGS="${TARGET_CPPFLAGS}" \
              LDFLAGS="${TARGET_LDFLAGS}"
  make
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_elfutils() {
  pkgdesc+=" (utilities)"
  license=(GPL-3.0-or-later)
  depends=(
    glibc
    libarchive libarchive.so
    libelf=$pkgver
    libgcc
    libstdc++
    sh
  )

  make DESTDIR="$pkgdir" install -C $pkgbase

  (
    cd "$pkgdir"
    _pick libelf usr/{include,lib}
    _pick libelf usr/share/man/*/{,lib}elf*
    
    # Clean up empty directory shells if created by make install
    rm -rf etc/debuginfod etc/profile.d usr/share/fish
  )

  install -vDm 644 $pkgbase/{AUTHORS,ChangeLog,NEWS,NOTES,README} -t "$pkgdir/usr/share/doc/$pkgname/"
}

package_libelf() {
  pkgdesc+=" (libraries)"
  license=('GPL-2.0-or-later OR LGPL-3.0-or-later')
  depends=(
    bzip2 libbz2.so
    curl libcurl.so
    glibc
    json-c
    xz liblzma.so
    zlib
    zstd libzstd.so
  )

  mv -v $pkgname/* "$pkgdir"
  install -vDm 644 $pkgbase/{AUTHORS,ChangeLog,NEWS,NOTES,README} -t "$pkgdir/usr/share/doc/$pkgname/"
}

