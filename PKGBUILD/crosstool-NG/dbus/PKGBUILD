prepare() {
  cd dbus
  patch -Np1 -i ../0001-Arch-Linux-tweaks.patch

  cat > "${srcdir}/cross-compilation.conf" <<EOF
[binaries]
c = '/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-gcc'
cpp = '/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-g++'
ar = '/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-ar'
strip = '/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-strip'
pkgconfig = 'pkg-config'

[built-in options]
c_args = ['--sysroot=/home/x/x-sysroot', '-O2']
cpp_args = ['--sysroot=/home/x/x-sysroot', '-O2']
c_link_args = ['--sysroot=/home/x/x-sysroot', '-L/home/x/x-sysroot/usr/lib']
cpp_link_args = ['--sysroot=/home/x/x-sysroot', '-L/home/x/x-sysroot/usr/lib']

[properties]
sys_root = '/home/x/x-sysroot'
pkg_config_libdir = '/home/x/x-sysroot/usr/lib/pkgconfig:/home/x/x-sysroot/usr/share/pkgconfig'

[host_machine]
system = 'linux'
cpu_family = 'arm'
cpu = 'armv6k'
endian = 'little'
EOF
}

build() {
  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS CHOST
  export PKG_CONFIG_PATH=""
  export PKG_CONFIG_LIBDIR="/home/x/x-sysroot/usr/lib/pkgconfig"

  local meson_options=(
    --prefix=/usr
    --cross-file="${srcdir}/cross-compilation.conf"
    -D apparmor=disabled
    -D dbus_user=dbus
    -D kqueue=disabled
    -D launchd=disabled
    -D relocation=disabled
    -D selinux=disabled
    -D x11_autolaunch=disabled
  )

  meson setup --wipe dbus build "${meson_options[@]}"
  meson compile -C build
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_dbus() {
  depends+=(
    libaudit.so
    libcap-ng.so
    libexpat.so
    libsystemd.so
  )
  provides=(
    libdbus
    libdbus-1.so
  )
  conflicts=(libdbus)
  replaces=(libdbus)

  meson install -C build --destdir "$pkgdir"

  # Normalize the nested sysroot path structure created by the Meson cross installer
  if [ -d "$pkgdir/home/x/x-sysroot/usr" ]; then
    mkdir -p "$pkgdir/usr"
    cp -a "$pkgdir/home/x/x-sysroot/usr/"* "$pkgdir/usr/"
    rm -rf "$pkgdir/home"
  fi

  # Catch standalone systemd layouts that escaped the sysroot nested build
  if [ -d "$pkgdir/lib/systemd" ]; then
    mkdir -p "$pkgdir/usr/lib"
    mv "$pkgdir/lib/systemd" "$pkgdir/usr/lib/"
    rmdir "$pkgdir/lib" --ignore-fail-on-non-empty
  fi

  _pick unit "$pkgdir"/usr/lib/systemd/{system,user}/dbus.service
  _pick docs "$pkgdir"/usr/share/doc

  install -Dt "$pkgdir/usr/share/libalpm/hooks" -m644 *.hook

  install -Dt "$pkgdir/usr/share/licenses/$pkgname" -m644 \
    dbus/COPYING dbus/LICENSES/AFL-2.1.txt
}

package_dbus-daemon-units() {
  pkgdesc+=" - Service units"
  depends=(dbus)
  provides=(dbus-units)
  conflicts=(dbus-broker-units)

  mv unit/* "$pkgdir"

  mkdir -p "$pkgdir/usr/share/licenses"
  ln -s dbus "$pkgdir/usr/share/licenses/$pkgname"
}

package_dbus-docs() {
  pkgdesc+=" - Documentation"
  depends=()

  mv docs/* "$pkgdir"

  install -Dt "$pkgdir/usr/share/licenses/$pkgname" -m644 \
    dbus/COPYING dbus/LICENSES/AFL-2.1.txt
}