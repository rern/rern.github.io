# Contributor: Allan McRae <allan@archlinux.org>
# Contributor: judd <jvinet@zeroflux.org>
# Cross-compiled for armv6h Raspberry Pi Zero via crosstool-ng

pkgname=grep
pkgver=3.12
pkgrel=2
pkgdesc='A string search utility (Cross-compiled for armv6h)'
arch=('armv6h')
license=('GPL-3.0-or-later')
url='https://www.gnu.org/software/grep/'
depends=('glibc' 'pcre2' 'sh')
makedepends=('gperf' 'git' 'python' 'texinfo' 'wget')
validpgpkeys=('155D3FC500C834486D1EEA677FD9FCCB000BEEEE') # Jim Meyering <meyering@meta.com>
source=("git+https://git.savannah.gnu.org/git/grep.git?signed#tag=v${pkgver}"
        "git+https://git.savannah.gnu.org/git/gnulib.git"
        "https://ftp.gnu.org/gnu/grep/grep-${pkgver}.tar.gz"{,.sig})
sha256sums=('9543190d9ca2201ea46fddaeb39031a0acde1f6aa4351a72f33ef3455e6dd41e'
            'SKIP'
            'badda546dfc4b9d97e992e2c35f3b5c7f20522ffcbe2f01ba1e9cdcbe7644cdc'
            'SKIP')

prepare() {
  cd "${pkgname}"

  git submodule init
  git config submodule.gnulib.url "${srcdir}/gnulib"
  git -c protocol.file.allow=always submodule update

  git cherry-pick -n \
    '2e19d07ef1c08c3ce4771bb1bfee1ae6541f1c0d'

  # bootstrap runs locally using host execution paths, variables are handled next in build()
  ./bootstrap \
    --skip-po
}

build() {
  TOOLCHAIN="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
  SYSROOT="/home/x/x-sysroot"

  # Unset host flags injected by native makepkg build profiles
  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS CHOST

  # Setup cross targets
  local TARGET_CC="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-gcc"
  local TARGET_CXX="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-g++"
  local TARGET_AR="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ar"
  local TARGET_RANLIB="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ranlib"
  local TARGET_LD="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ld"

  local TARGET_CFLAGS="--sysroot=${SYSROOT} -O2"
  local TARGET_CXXFLAGS="--sysroot=${SYSROOT} -O2"
  local TARGET_CPPFLAGS="--sysroot=${SYSROOT}"
  local TARGET_LDFLAGS="--sysroot=${SYSROOT} -L${SYSROOT}/usr/lib"

  # Safe injection of libtool configuration variables to avoid host relinking failures
  export LTFLAGS="-no-fast-install"
  export AM_LIBTOOLFLAGS="-no-fast-install"

  cd "${pkgname}"

  ./configure \
    --host=armv6-rpi-linux-gnueabihf \
    --build=$(gcc -dumpmachine) \
    --with-sysroot="${SYSROOT}" \
    --prefix=/usr \
    --disable-gcc-warnings \
    CC="${TARGET_CC}" \
    CXX="${TARGET_CXX}" \
    AR="${TARGET_AR}" \
    RANLIB="${TARGET_RANLIB}" \
    LD="${TARGET_LD}" \
    CFLAGS="${TARGET_CFLAGS}" \
    CXXFLAGS="${TARGET_CXXFLAGS}" \
    CPPFLAGS="${TARGET_CPPFLAGS}" \
    LDFLAGS="${TARGET_LDFLAGS}"

  make

  # Generate grep mo files from dist tarball (compiled on host using native tools)
  cd "${srcdir}/${pkgname}-${pkgver}/po"
  for po in *.po; do
    msgfmt "${po}" -o "${po%.po}.mo"
  done
}

# Omit check() because target binaries cannot execute on x86_64 build host

package() {
  cd "${pkgname}"

  make DESTDIR="$pkgdir" install

  # Install grep mo files from dist tarball
  cd "${srcdir}/${pkgname}-${pkgver}/po"
  for mo in *.mo; do
    install -Dm 644 "${mo}" "${pkgdir}/usr/share/locale/${mo%.mo}/LC_MESSAGES/${pkgname}.mo"
  done
}