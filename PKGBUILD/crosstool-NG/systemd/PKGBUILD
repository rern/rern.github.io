# Maintainer: Your Name <you@example.com>
pkgbase=systemd
pkgname=('systemd' 'systemd-libs')
pkgver=260.2
pkgrel=1
pkgdesc="systemd system and service manager (ARMv6h minimal build)"
arch=('armv6h')
url="https://www.freedesktop.org/wiki/Software/systemd/"
license=('GPL2' 'LGPL2.1')
makedepends=('meson' 'ninja' 'gcc' 'pkgconf' 'python')
source=("https://github.com/systemd/systemd/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/systemd-${pkgver}"
  mkdir -p builddir
}

build() {
  cd "${srcdir}/systemd-${pkgver}/builddir"

  local _meson_options=(
    -Dversion-tag="${pkgver}-${pkgrel}-arch"
    -Dmode=release

    # Disable unsupported features
    -Dseccomp=disabled
    -Dapparmor=disabled
    -Dselinux=disabled
    -Dbpf-framework=disabled
    -Dima=false
    -Dlibcryptsetup=disabled
    -Dlibcryptsetup-plugins=disabled
    -Dimportd=disabled
    -Dsysupdate=disabled
    -Dhomed=disabled
    -Dremote=disabled
    -Dinstall-tests=false
    -Dukify=disabled
    -Dxenctrl=disabled
    -Dmicrohttpd=disabled
    -Dlibfido2=disabled

    # Libraries / features
    -Dlibidn2=enabled
    -Dlz4=enabled
    -Dzstd=enabled
    -Dxz=enabled
    -Dbzip2=enabled
    -Dman=enabled

    # Paths / defaults
    -Ddbuspolicydir=/usr/share/dbus-1/system.d
    -Ddefault-dnssec=no
    -Ddefault-locale=C
    -Dlocalegen-path=/usr/bin/locale-gen
    -Ddns-over-tls=openssl
    -Dfallback-hostname='archlinux'
    -Dnologin-path=/usr/bin/nologin
    -Drpmmacrosdir=no
    -Dsysvinit-path=
    -Dsysvrcnd-path=

    # SBAT metadata
    -Dsbat-distro='arch'
    -Dsbat-distro-summary='Arch Linux ARM'
    -Dsbat-distro-pkgname="${pkgbase}"
    -Dsbat-distro-version="${pkgver}"
    -Dsbat-distro-url="https://archlinuxarm.org/packages/armv6h/${pkgbase}"
  )

  meson setup .. "${_meson_options[@]}"
  ninja
}

package_systemd() {
  pkgdesc="systemd system and service manager (ARMv6h minimal build)"
  depends=('glibc' 'util-linux' 'xz' 'zstd' 'bzip2' 'lz4' 'libidn2' 'pcre2' 'acl' 'libgcrypt' 'dbus')
  provides=('init')
  conflicts=('sysvinit')

  cd "${srcdir}/systemd-${pkgver}/builddir"
  DESTDIR="${pkgdir}" meson install

  # Ensure runtime directories exist
  install -dm755 "${pkgdir}/var/lib/systemd"
  install -dm755 "${pkgdir}/var/log/journal"
  chown root:root "${pkgdir}/var/log/journal"
  chmod 755 "${pkgdir}/var/log/journal"

  # Remove remote journal dir (disabled)
  rm -rf "${pkgdir}/var/log/journal/remote"

  # Ensure config dirs exist
  install -dm755 "${pkgdir}/usr/lib/tmpfiles.d"
  install -dm755 "${pkgdir}/usr/lib/sysusers.d"
  install -dm755 "${pkgdir}/usr/lib/systemd/system-preset"
  install -dm755 "${pkgdir}/usr/lib/systemd/system"
  install -dm755 "${pkgdir}/usr/lib/systemd/user"
}

package_systemd-libs() {
  pkgdesc="systemd client libraries (libsystemd, libudev)"
  depends=('glibc')
  provides=('libsystemd.so' 'libudev.so')

  cd "${srcdir}/systemd-${pkgver}/builddir"
  DESTDIR="${pkgdir}" meson install

  # Keep only libraries and pkgconfig files
  install -dm755 "${pkgdir}/usr/lib/pkgconfig"

  # Remove everything else not needed in -libs
  rm -rf "${pkgdir}/usr/bin"
  rm -rf "${pkgdir}/usr/lib/systemd"
  rm -rf "${pkgdir}/usr/share"
  rm -rf "${pkgdir}/etc"
  rm -rf "${pkgdir}/var"
}
