# Maintainer: Your Name <you@example.com>
pkgbase=systemd
pkgname=('systemd' 'systemd-libs')
pkgver=260.2
pkgrel=2
pkgdesc="systemd system and service manager (ARMv6h minimal build)"
arch=('armv6h')
url="https://www.freedesktop.org/wiki/Software/systemd/"
license=('GPL2' 'LGPL2.1')
makedepends=('meson' 'ninja' 'gcc' 'pkgconf' 'python')
source=("https://github.com/systemd/systemd/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/systemd-${pkgver}"
  # Clean out any partial historical configure configurations 
  rm -rf builddir
}

build() {
  cd "${srcdir}/systemd-${pkgver}"

  # Completely clear host variables to prevent compilation contamination
  unset CFLAGS CXXFLAGS LDFLAGS
  
  # Tell pkg-config globally to translate package data paths through the sysroot
  export PKG_CONFIG_SYSROOT_DIR="/home/x/x-sysroot"
  export PKG_CONFIG_LIBDIR="/home/x/x-sysroot/usr/lib/pkgconfig"

  local _meson_options=(
    --cross-file "/home/x/x-tools/cross-file.txt"
    
    --prefix=/usr
    --sysconfdir=/etc
    --localstatedir=/var
    --default-library both

    -Dversion-tag="${pkgver}-${pkgrel}-arch"
    -Dmode=release

    # Disable unsupported features & sandbox failure culprits
    -Dseccomp=disabled
    -Dapparmor=disabled
    -Dselinux=disabled
    -Dbpf-framework=disabled
    -Dima=false
    -Dlibcryptsetup=disabled
    -Dlibcryptsetup-plugins=disabled
    -Dimportd=disabled
    -Dsysupdate=disabled
    -Dhomed=disabled
    -Dremote=disabled
    -Dinstall-tests=false
    -Dtests=false
    -Dukify=disabled
    -Dxenctrl=disabled
    -Dmicrohttpd=disabled
    -Dlibfido2=disabled
    
    # Explicitly disable gcrypt features to stop "gcrypt.h" build errors
    -Dgcrypt=disabled
    -Dqrencode=disabled

    # Libraries / features
    -Dlibidn2=enabled
    -Dlz4=enabled
    -Dzstd=enabled
    -Dxz=enabled
    -Dbzip2=enabled
    -Dman=enabled

    # Paths / defaults
    -Ddbuspolicydir=/usr/share/dbus-1/system.d
    -Ddefault-dnssec=no
    -Ddefault-locale=C
    -Dlocalegen-path=/usr/bin/locale-gen
    -Ddns-over-tls=openssl
    -Dfallback-hostname='archlinux'
    -Dnologin-path=/usr/bin/nologin
    -Drpmmacrosdir=no
    -Dsysvinit-path=
    -Dsysvrcnd-path=

    # SBAT metadata
    -Dsbat-distro='arch'
    -Dsbat-distro-summary='Arch Linux ARM'
    -Dsbat-distro-pkgname="${pkgbase}"
    -Dsbat-distro-version="${pkgver}"
    -Dsbat-distro-url="https://archlinuxarm.org/packages/armv6h/${pkgbase}"
  )

  # Clear out old cached directory structures to apply cross-file modifications
  rm -rf builddir

  # Fire up configuration checks and start the build
  meson setup builddir "${_meson_options[@]}"
  meson compile -C builddir
}

package_systemd() {
  pkgdesc="systemd system and service manager (ARMv6h minimal build)"
  depends=('systemd-libs' 'util-linux' 'xz' 'zstd' 'bzip2' 'lz4' 'libidn2' 'pcre2' 'acl' 'libgcrypt' 'dbus')
  provides=('init' 'udev')
  conflicts=('sysvinit')

  cd "${srcdir}/systemd-${pkgver}"
  DESTDIR="${pkgdir}" meson install -C builddir

  # Split Package Cleanup: Strip library files handled by systemd-libs package target
  rm -rf "${pkgdir}/usr/include"
  rm -f "${pkgdir}"/usr/lib/lib*.so*

  # Ensure runtime directories exist
  install -dm755 "${pkgdir}/var/lib/systemd"
  install -dm755 "${pkgdir}/var/log/journal"

  # Ensure config dirs exist
  install -dm755 "${pkgdir}/usr/lib/tmpfiles.d"
  install -dm755 "${pkgdir}/usr/lib/sysusers.d"
  install -dm755 "${pkgdir}/usr/lib/systemd/system-preset"
}

package_systemd-libs() {
  pkgdesc="systemd client libraries (libsystemd, libudev)"
  depends=('glibc')
  provides=('libsystemd.so=0-32' 'libudev.so=1-32')

  cd "${srcdir}/systemd-${pkgver}"
  
  # Install into a temp stage directory to safely separate shared files
  DESTDIR="${srcdir}/lib-stage" meson install -C builddir

  # Deploy only the essential library payload profiles
  install -dm755 "${pkgdir}/usr/lib"
  cp -a "${srcdir}/lib-stage/usr/lib"/lib*.so* "${pkgdir}/usr/lib/"
  cp -a "${srcdir}/lib-stage/usr/lib/pkgconfig" "${pkgdir}/usr/lib/"
  cp -a "${srcdir}/lib-stage/usr/include" "${pkgdir}/usr/"
}