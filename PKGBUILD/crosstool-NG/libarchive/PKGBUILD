# Maintainer: Adapted for ARMv6h cross-compile (Raspberry Pi Zero)

pkgname=libarchive
pkgver=3.8.8
pkgrel=1
pkgdesc='Multi-format archive and compression library (cross-compiled for armv6h, OpenSSL 3)'
arch=('armv6h')
url='https://libarchive.org/'
license=('BSD-2-Clause')
depends=(
  acl libacl.so
  bzip2 libbz2.so
  glibc
  libxml2 libxml2.so
  lz4
  openssl libcrypto.so libssl.so
  xz liblzma.so
  zlib libz.so
  zstd libzstd.so
)
makedepends=('git' 'autoconf' 'automake' 'libtool')
provides=('libarchive.so')
source=("git+https://github.com/${pkgname}/${pkgname}.git#tag=v${pkgver}")
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}"
  autoreconf -fiv
}

build() {
  cd "${pkgname}"

  # Cross toolchain
  export CC=/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-gcc
  export CXX=/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-g++
  export AR=/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-ar
  export RANLIB=/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin/armv6-rpi-linux-gnueabihf-ranlib

  # pkg-config sysroot
  export PKG_CONFIG_LIBDIR=/home/x/x-sysroot/usr/lib/pkgconfig
  export PKG_CONFIG_SYSROOT_DIR=/home/x/x-sysroot

  # Pre-seed configure cache to skip runtime tests
  export ac_cv_func_malloc_0_nonnull=yes
  export ac_cv_func_realloc_0_nonnull=yes
  export ac_cv_func_memcmp_working=yes
  export ac_cv_func_strerror_r=yes
  export ac_cv_func_strerror_r_char_p=no

  # ARMv6-safe flags
  export CFLAGS="-O2 -pipe -march=armv6 -mfpu=vfp -mfloat-abi=hard"
  export CXXFLAGS="$CFLAGS"

  # Explicit sysroot include/lib paths so configure finds libxml2
  export CPPFLAGS="--sysroot=/home/x/x-sysroot -I/home/x/x-sysroot/usr/include/libxml2"
  export LDFLAGS="--sysroot=/home/x/x-sysroot -L/home/x/x-sysroot/usr/lib"

  ./configure \
    --build=x86_64-pc-linux-gnu \
    --host=armv6-rpi-linux-gnueabihf \
    --prefix=/usr \
    --disable-static \
    --without-nettle \
    --without-libb2 \
    --with-openssl

  make
}


check() {
  cd "${pkgname}"
  echo "Skipping make check in cross build"
}

package() {
  cd "${pkgname}"
  make DESTDIR="$pkgdir" install
  install -Dm0644 COPYING "$pkgdir/usr/share/licenses/libarchive/COPYING"
}
