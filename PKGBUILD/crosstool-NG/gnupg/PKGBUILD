prepare() {
  cd "$pkgname"

  local src
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ $src = *.patch ]] || continue
    printf "Applying patch %s...\n" "$src"
    
    # Added -f (forward) to skip already applied patches and --batch to suppress prompts
    patch -Np1 -f --batch < "../$src" || echo "Patch $src skipped or already applied."
  done

  sed -n '5, 28 p' COPYING.other > MIT.txt
  sed -n '30, 60 p' COPYING.other > BSD-4-Clause.txt
  sed -n '62, 92 p' COPYING.other > BSD-3-Clause.txt
  sed -n '95, 125 p' COPYING.other > BSD-2-Clause.txt
  sed -n '128, 160 p' COPYING.other > Unicode-TOU.txt

  ./autogen.sh
}

build() {
  TOOLCHAIN="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
  SYSROOT="/home/x/x-sysroot"

  # Unset host flags injected by makepkg
  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS CHOST

  # Local variables for the cross-compilation target environment
  local TARGET_CC="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-gcc"
  local TARGET_CXX="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-g++"
  local TARGET_AR="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ar"
  local TARGET_RANLIB="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ranlib"
  local TARGET_LD="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ld"

  local TARGET_CFLAGS="--sysroot=${SYSROOT} -O2"
  local TARGET_CXXFLAGS="--sysroot=${SYSROOT} -O2"
  local TARGET_CPPFLAGS="--sysroot=${SYSROOT}"
  
  # REMOVED -no-fast-install from here so compiler sanity checks pass!
  local TARGET_LDFLAGS="--sysroot=${SYSROOT} -L${SYSROOT}/usr/lib"

  # EXPORT Libtool-specific flags cleanly so it bypasses compiler tests
  export LTFLAGS="-no-fast-install"
  export AM_LIBTOOLFLAGS="-no-fast-install"

  local configure_options=(
    --host=armv6-rpi-linux-gnueabihf
    --build=$(gcc -dumpmachine)
    --with-sysroot="${SYSROOT}"
    --enable-g13
    --enable-large-secmem
    --enable-maintainer-mode
    --libexecdir=/usr/lib/gnupg
    --prefix=/usr
    --sbindir=/usr/bin
    --sysconfdir=/etc
    --disable-doc
  )

  cd "$pkgname"

  ./configure "${configure_options[@]}" \
    CC="${TARGET_CC}" \
    CXX="${TARGET_CXX}" \
    AR="${TARGET_AR}" \
    RANLIB="${TARGET_RANLIB}" \
    LD="${TARGET_LD}" \
    CFLAGS="${TARGET_CFLAGS}" \
    CXXFLAGS="${TARGET_CXXFLAGS}" \
    CPPFLAGS="${TARGET_CPPFLAGS}" \
    LDFLAGS="${TARGET_LDFLAGS}"

  make
}
# Omit check() because target binaries cannot execute on x86_64 build host

package() {
  depends+=(
    bzip2 libbz2.so
    libassuan libassuan.so
    npth libnpth.so
    readline libreadline.so
  )

  cd "$pkgname"
  make DESTDIR="$pkgdir" install

  ln -s gpg "$pkgdir"/usr/bin/gpg2
  ln -s gpgv "$pkgdir"/usr/bin/gpgv2

  # Omitted manual page configuration as requested. Kept licensing.
  install -vDm 644 {BSD-{2,3,4}-Clause,MIT,Unicode-TOU}.txt -t "$pkgdir/usr/share/licenses/$pkgname/"

  local systemdir="$pkgdir/usr/lib/systemd/"
  local wantsdir="${systemdir}user/sockets.target.wants/"
  install -vdm 755 "$wantsdir"

  local unit
  for unit in ../*.{service,socket}; do
    case $unit in
      *@.*) install -vDm 644 "$unit" -t "${systemdir}system/" ;;
      *.socket) ln -sv "../${unit##*/}" -t "$wantsdir" ;&
      *) install -vDm 644 "$unit" -t "${systemdir}user/" ;;
    esac
  done
}