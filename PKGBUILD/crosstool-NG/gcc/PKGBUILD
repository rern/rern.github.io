# Maintainer: You
pkgbase=gcc
pkgname=(gcc gcc-libs libgcc libstdc++ libubsan)
pkgver=16.1.1+r12+g301eb08fa2c5
_commit=301eb08fa2c5b6f3045260bf1294c2e2bacbcd90
pkgrel=1
pkgdesc='GNU Compiler Collection (crosstool-ng armv6h Raspberry Pi Zero)'
arch=(armv6h)
license=('GPL-3.0-or-later WITH GCC-exception-3.1' 'GFDL-1.3-or-later')
url='https://gcc.gnu.org'

makedepends=(binutils git libmpc mpfr gmp zstd python)
options=(!emptydirs !lto strip)

_target="armv6-rpi-linux-gnueabihf"
_sysroot="/home/x/x-sysroot"
_toolchain="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
_libdir="usr/lib/gcc/${_target}/${pkgver%%.*}"

source=("git+https://sourceware.org/git/gcc.git#commit=$_commit")
sha256sums=('SKIP')

pkgver() {
  cd gcc
  echo "$(cat gcc/BASE-VER)+$(git describe --abbrev=12 --tags | sed 's/[^-]*-[^-]*-//;s/[^-]*-/r&/;s/-/+/g;s/_/./')"
}

prepare() {
  cd gcc
  mkdir -p "$srcdir/gcc-build"
}

build() {
  unset CFLAGS CXXFLAGS LDFLAGS
  cd "$srcdir/gcc-build"
  local _confflags=(
      --target=$_target --with-sysroot=$_sysroot --prefix=/usr
      --libdir=/usr/lib --libexecdir=/usr/lib --program-prefix=$_target-
      --with-gcc-major-version-only --with-linker-hash-style=gnu --with-system-zlib
      --enable-checking=release --enable-clocale=gnu --enable-default-pie
      --enable-default-ssp --enable-shared --enable-threads=posix
      --disable-bootstrap --disable-multilib --disable-fixincludes --disable-libssp
      --disable-libstdcxx-pch --disable-werror --with-arch=armv6zk --with-fpu=vfp --with-float=hard
  )
  ../gcc/configure --enable-languages=c,c++ "${_confflags[@]}"
  make -O
}

check() { echo "Skipping test suites."; }

package_gcc() {
  pkgdesc="GNU Compiler Collection - C/C++ frontends"
  depends=("gcc-libs=$pkgver-$pkgrel" "libgcc=$pkgver-$pkgrel" "libstdc++=$pkgver-$pkgrel" "libubsan=$pkgver-$pkgrel")
  cd "$srcdir/gcc-build"
  make -C gcc DESTDIR="$pkgdir" install-driver install-cpp install-gcc-ar \
    c++.install-common install-headers install-plugin install-lto-wrapper
  install -m755 -t "$pkgdir/usr/bin/" gcc/gcov{,-tool}
  ln -s gcc "$pkgdir/usr/bin/cc"
}

package_gcc-libs() {
  pkgdesc="Runtime libraries shipped by GCC"
  depends=('glibc')
  cd "$srcdir/gcc-build"
  make -C $_target/libgcc DESTDIR="$pkgdir" install-shared
  make -C $_target/libstdc++-v3/src DESTDIR="$pkgdir" install-toolexeclibLTLIBRARIES
  make -C $_target/libstdc++-v3/include DESTDIR="$pkgdir" install
}

package_libgcc() {
  pkgdesc="Low-level runtime library shipped by GCC"
  depends=('glibc')
  provides=(libgcc_s.so)
  cd "$srcdir/gcc-build"
  make -C $_target/libgcc DESTDIR="$pkgdir" install-shared
  rm -f "$pkgdir/$_libdir/libgcc_eh.a"
  install -d -m0755 "$pkgdir/usr/lib"
  ln -s libgcc_s.so.1 "$pkgdir/usr/lib/libgcc_s.so.1"
}

package_libstdc++() {
  pkgdesc="C++ runtime libraries shipped by GCC"
  depends=('glibc' libgcc)
  provides=(libstdc++.so)
  cd "$srcdir/gcc-build"
  make -C $_target/libstdc++-v3/src DESTDIR="$pkgdir" install-toolexeclibLTLIBRARIES
  make -C $_target/libstdc++-v3/po DESTDIR="$pkgdir" install
  install -d -m0755 "$pkgdir/usr/lib"
  ln -s libstdc++.so.6.0.35 "$pkgdir/usr/lib/libstdc++.so.6"
}

package_libubsan() {
  pkgdesc="Undefined Behavior Sanitizer runtime library shipped by GCC"
  depends=('glibc' libgcc libstdc++)
  provides=(libubsan.so)
  cd "$srcdir/gcc-build"
  make -C $_target/libsanitizer/ubsan DESTDIR="$pkgdir" install-toolexeclibLTLIBRARIES
}
