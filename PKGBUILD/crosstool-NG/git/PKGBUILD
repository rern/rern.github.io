# Cross-compiled for armv6h via crosstool-ng (Docs/Man excluded)

pkgbase=git
pkgname=(git git-zsh-completion)
pkgver=2.54.0
pkgrel=1
pkgdesc='The fast distributed version control system (Cross-compiled for armv6h)'
arch=('armv6h')
url='https://git-scm.com/'
license=('GPL-2.0-only')
# Modified to bypass entirely absent armv6h online repositories
depends=('curl' 'expat' 'perl' 'openssl' 'pcre2' 'grep' 'shadow' 'zlib')
makedepends=('python' 'git') # Removed xmlto, asciidoc, and rust
checkdepends=('openssh')
install=git.install
validpgpkeys=('96E07AF25771955980DAD10020D04E5A713660A7') # Junio C Hamano
options=('!docs')
source=("git+https://github.com/git/git?signed#tag=v${pkgver}"
        'git-daemon@.service'
        'git-daemon.socket'
        'git-sysusers.conf')
sha256sums=('a185bb4716fe77d02d8cf81080686c580fece76e0289593871810c83f2c912a1'
            '14c0b67cfe116b430645c19d8c4759419657e6809dfa28f438c33a005245ad91'
            'ac4c90d62c44926e6d30d18d97767efc901076d4e0283ed812a349aece72f203'
            '7630e8245526ad80f703fac9900a1328588c503ce32b37b9f8811674fcda4a45')

# --- Cross-Compiling Environment Setup ---
_cross_bin="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
_target_triple="armv6-rpi-linux-gnueabihf"
_sysroot="/home/x/rpi0_sysroot"

_make() {
  local make_options=(
    prefix='/usr'
    gitexecdir='/usr/lib/git-core'
    perllibdir="/usr/share/perl5/vendor_perl" # Explicit path; avoids executing host perl

    # Bind toolchain compiler targets
    CC="${_cross_bin}/${_target_triple}-gcc"
    CXX="${_cross_bin}/${_target_triple}-g++"
    AR="${_cross_bin}/${_target_triple}-ar"
    
    # Inject target architecture flags alongside the sysroot location
    CFLAGS="-O2 -pipe -march=armv6zk -mcpu=arm1176jzf-s -mfpu=vfp -mfloat-abi=hard --sysroot=${_sysroot} -I${_sysroot}/usr/include"
    
    # Secure library flags while bypassing the host libatomic_asneeded.so issue
    LDFLAGS="-Wl,-O1,--sort-common,--as-needed,-z,relro,-z,now --sysroot=${_sysroot} -L${_sysroot}/usr/lib -L${_sysroot}/lib -Wl,-rpath-link,${_sysroot}/usr/lib -lssl -lcrypto -latomic"

    INSTALL_SYMLINKS=1
    MAN_BOLD_LITERAL=1
    NO_PERL_CPAN_FALLBACKS=1
    USE_LIBPCRE2=1
    
    # Disable features requiring non-standard libraries or extra language cross-chains
    ZLIB_NG=
    WITH_RUST=
  )

  make "${make_options[@]}" "$@"
}

prepare() {
  cd "$pkgbase"

  cat > config.mak << EOF
X=
NEEDS_CRYPTO_WITH_SSL=YesPlease
HAVE_DEV_TTY=YesPlease
EOF
}

build() {
  cd "$pkgbase"

  export PATH="${_cross_bin}:${PATH}"
  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS

  # 'man' build targets removed completely
  _make all

  _make -C contrib/credential/libsecret
  _make -C contrib/subtree all
  _make -C contrib/diff-highlight
}

check() {
  echo "Skipping validation test suite: host/target environment architecture mismatch."
}

package_git() {
  optdepends=(
    'git-zsh-completion: upstream zsh completion'
    'tk: gitk and git gui'
    'openssh: ssh transport and crypto'
    'perl-error: git send-email/svn support (Requires manual compile)'
    'perl-mailtools: git send-email/svn support (Requires manual compile)'
    'less: the default pager for git'
  )
  cd "$pkgbase"
  export PATH="${_cross_bin}:${PATH}"

  # 'install-man' removed completely
  _make DESTDIR="$pkgdir" install

  # bash completion
  mkdir -p "$pkgdir"/usr/share/bash-completion/completions/
  install -m 0644 ./contrib/completion/git-completion.bash "$pkgdir"/usr/share/bash-completion/completions/git
  
  # fancy git prompt
  mkdir -p "$pkgdir"/usr/share/git/
  install -m 0644 ./contrib/completion/git-prompt.sh "$pkgdir"/usr/share/git/git-prompt.sh
  
  # libsecret credentials helper
  install -m 0755 contrib/credential/libsecret/git-credential-libsecret \
      "$pkgdir"/usr/lib/git-core/git-credential-libsecret
  _make -C contrib/credential/libsecret clean
  
  # subtree installation (without man pages)
  _make -C contrib/subtree DESTDIR="$pkgdir" install
  
  # copy remaining contrib files
  find contrib/ -name '.gitignore' -delete
  cp -a ./contrib/* "$pkgdir"/usr/share/git/

  # git-daemon activation configs
  install -D -m 0644 "$srcdir"/git-daemon@.service "$pkgdir"/usr/lib/systemd/system/git-daemon@.service
  install -D -m 0644 "$srcdir"/git-daemon.socket "$pkgdir"/usr/lib/systemd/system/git-daemon.socket

  # sysusers file setup
  install -D -m 0644 "$srcdir"/git-sysusers.conf "$pkgdir"/usr/lib/sysusers.d/git.conf

  # Strip target binaries to decrease deployment footprint
  find "$pkgdir/usr/bin" "$pkgdir/usr/lib" -type f \( -name "*.so*" -o -executable \) \
    -exec "${_cross_bin}/${_target_triple}-strip" --strip-unneeded {} + 2>/dev/null || true
}

package_git-zsh-completion() {
  pkgdesc='the fast distributed version control system - upstream zsh completion'
  depends=('git' 'zsh')

  install -d "$pkgdir"/usr/share/zsh/site-functions/
  ln -s ../../git/completion/git-completion.zsh "$pkgdir"/usr/share/zsh/site-functions/_git
}