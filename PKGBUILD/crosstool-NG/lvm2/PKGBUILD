# Maintainer: Eric Bélanger <eric@archlinux.org>
# Maintainer: Thomas Bächler <thomas@archlinux.org>
# Modified for Cross-Compilation targeting armv6h (Raspberry Pi Zero)
# Omitted man pages, documentation, and static files

pkgbase=lvm2
pkgdesc='Device mapper and Logical Volume Manager (Cross-Compiled for armv6h)'
pkgname=('lvm2' 'device-mapper')
pkgver=2.03.41
pkgrel=1
arch=('armv6h')
url='https://sourceware.org/lvm2/'
license=('GPL-2.0-only' 'LGPL-2.1-only')
# Omitted tools like thin-provisioning-tools from host requirements if needed, keeping target mappings
makedepends=('git' 'systemd' 'libaio' 'thin-provisioning-tools')
source=("git+https://gitlab.com/lvmteam/lvm2.git#tag=v${pkgver//./_}"
        '0001-libdm-Makefile-add-an-empty-target-install_lvm2.patch')
sha256sums=('SKIP'
            '867a9ea522754144cd33d203a9400013bb9209925db9ef033b07dd586eda69dd')

_backports=()

prepare() {
  cd lvm2/

  local _c
  for _c in "${_backports[@]}"; do
    git log --oneline -1 "${_c}"
    git show "${_c}" -- ':(exclude)WHATS_NEW' | git apply
  done

  # remove install section from systemd units that are enabled by default
  sed -i -e '/^\[Install\]$/,$d' \
    scripts/dm_event_systemd_red_hat.socket.in \
    scripts/lvm2_lvmpolld_systemd_red_hat.socket.in \
    scripts/lvm2_monitoring_systemd_red_hat.service.in

  # libdm/Makefile: add an empty target install_lvm2
  patch -Np1 < ../0001-libdm-Makefile-add-an-empty-target-install_lvm2.patch
}

build() {
  export CONFIG_SHELL=/bin/bash
  export PATH="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin:$PATH"
  export PKG_CONFIG_SYSROOT_DIR="/home/x/x-sysroot"
  export PKG_CONFIG_PATH="/home/x/x-sysroot/usr/lib/pkgconfig:/home/x/x-sysroot/usr/share/pkgconfig"

  # Scrub default host build flags to ensure clean target isolation
  export CFLAGS="--sysroot=/home/x/x-sysroot"
  export CXXFLAGS="--sysroot=/home/x/x-sysroot"
  export LDFLAGS="--sysroot=/home/x/x-sysroot"

  # Explicitly declare your crosstool-NG toolchain components to Autotools
  export CC="armv6-rpi-linux-gnueabihf-gcc"
  export CXX="armv6-rpi-linux-gnueabihf-g++"
  export AR="armv6-rpi-linux-gnueabihf-ar"
  export RANLIB="armv6-rpi-linux-gnueabihf-ranlib"
  export STRIP="armv6-rpi-linux-gnueabihf-strip"

  cd lvm2/

  ./configure \
    --host=armv6-rpi-linux-gnueabihf \
    CONFIG_SHELL=/bin/bash \
    --prefix=/usr \
    --sbindir=/usr/bin \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --enable-cmdlib \
    --enable-dmeventd \
    --enable-lvmpolld \
    --enable-pkgconfig \
    --enable-readline \
    --enable-udev_rules \
    --enable-udev_sync \
    --enable-write_install \
    --with-cache=internal \
    --with-default-dm-run-dir=/run \
    --with-default-locking-dir=/run/lock/lvm \
    --with-default-pid-dir=/run \
    --with-default-run-dir=/run/lvm \
    --with-libexecdir=/usr/lib/lvm2 \
    --with-systemdsystemunitdir=/usr/lib/systemd/system \
    --with-thin=internal \
    --with-udev-prefix=/usr
  make
}

package_device-mapper() {
  pkgdesc='Device mapper userspace library and tools (Cross-Compiled)'
  url='http://sourceware.org/dm/'
  depends=(
    'bash'
    'glibc'
    'libgcc' 'libgcc_s.so'
    'systemd-libs' 'libudev.so')
  provides=('libdevmapper.so' 'libdevmapper-event.so')

  cd lvm2/

  make DESTDIR="${pkgdir}" install_device-mapper
  make DESTDIR="${pkgdir}" install_systemd_units
  
  rm -f "${pkgdir}/usr/lib/systemd/system/"blk-availability.service,lvm*}
  install -d -m0755 "${pkgdir}/usr/lib/systemd/system/sockets.target.wants"
  ln -sf ../dm-event.socket "${pkgdir}/usr/lib/systemd/system/sockets.target.wants/dm-event.socket"

  # Explicit clean sweep: scrub manual layouts and documentation components completely
  rm -rf "${pkgdir}/usr/share/man"
  rm -rf "${pkgdir}/usr/share/doc"
}

package_lvm2() {
  pkgdesc='Logical Volume Manager 2 utilities (Cross-Compiled)'
  url='https://sourceware.org/lvm2/'
  depends=(
    'bash'
    "device-mapper>=${pkgver}"
    'glibc'
    'libaio' 'libaio.so'
    'readline' 'libreadline.so'
    'systemd-libs' 'libudev.so'
    'thin-provisioning-tools'
    'util-linux-libs' 'libblkid.so')
  conflicts=('lvm' 'mkinitcpio<38-1')
  backup=('etc/lvm/lvm.conf' 'etc/lvm/lvmlocal.conf')

  cd lvm2/

  make -j1 DESTDIR="${pkgdir}" install_lvm2
  install -d "${pkgdir}"/etc/lvm/{archive,backup}

  make DESTDIR="${pkgdir}" install_systemd_units
  rm -f "${pkgdir}/usr/lib/systemd/system/"dm-*
  install -d -m0755 "${pkgdir}/usr/lib/systemd/system/sysinit.target.wants"
  ln -sf ../lvm2-lvmpolld.socket "${pkgdir}/usr/lib/systemd/system/sysinit.target.wants/lvm2-lvmpolld.socket"
  ln -sf ../lvm2-monitor.service "${pkgdir}/usr/lib/systemd/system/sysinit.target.wants/lvm2-monitor.service"
  make DESTDIR="${pkgdir}" install_systemd_generators

  # Split clean sweep: ensure man pages don't leak through the lvm2 package closure
  rm -rf "${pkgdir}/usr/share/man"
  rm -rf "${pkgdir}/usr/share/doc"
}