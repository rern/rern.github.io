pkgbase=openldap
pkgname=('openldap' 'libldap')
pkgver=2.6.13
pkgrel=1
arch=('armv6h')
url="https://www.openldap.org/"
license=('custom')
# PREVENT host makepkg from trying to strip ARM binaries at the end
options=('!strip')

source=(
  "https://www.openldap.org/software/download/OpenLDAP/openldap-release/${pkgbase}-${pkgver}.tgz"
  "openldap.tmpfiles"
  "openldap.sysusers"
)
sha256sums=('SKIP' 'SKIP' 'SKIP')

_sysroot="/home/x/x-sysroot"
_toolchain_bin="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"

prepare() {
  cd "${srcdir}/${pkgbase}-${pkgver}"

  sed -i 's|-m 644 $(LIBRARY)|-m 755 $(LIBRARY)|' libraries/{liblber,libldap}/Makefile.in
  sed -i 's|#define LDAPI_SOCK LDAP_RUNDIR LDAP_DIRSEP "run" LDAP_DIRSEP "ldapi"|#define LDAPI_SOCK LDAP_DIRSEP "run" LDAP_DIRSEP "openldap" LDAP_DIRSEP "ldapi"|' include/ldap_defaults.h
  sed -i 's|%LOCALSTATEDIR%/run|/run/openldap|' servers/slapd/slapd.{conf,ldif}
  sed -i 's|-$(MKDIR) $(DESTDIR)$(localstatedir)/run|-$(MKDIR) $(DESTDIR)/run/openldap|' servers/slapd/Makefile.in
}

build() {
  cd "${srcdir}/${pkgbase}-${pkgver}"

  export PATH="${_toolchain_bin}:$PATH"
  export CC=armv6-rpi-linux-gnueabihf-gcc
  export LD=armv6-rpi-linux-gnueabihf-ld
  export AR=armv6-rpi-linux-gnueabihf-ar
  export RANLIB=armv6-rpi-linux-gnueabihf-ranlib
  export STRIP=armv6-rpi-linux-gnueabihf-strip

  export CFLAGS="-O2 -march=armv6 -mfloat-abi=hard -mfpu=vfp --sysroot=${_sysroot}"
  export CPPFLAGS="--sysroot=${_sysroot} -I${_sysroot}/usr/include"
  export CXXFLAGS="${CFLAGS}"
  export LDFLAGS="-Wl,-O1,--as-needed --sysroot=${_sysroot} -L${_sysroot}/usr/lib"

  export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"
  export PKG_CONFIG_PATH="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"

  autoconf
  ./configure \
    --host=armv6-rpi-linux-gnueabihf \
    --prefix=/usr \
    --with-sysroot="${_sysroot}" \
    --enable-dynamic --enable-syslog --enable-ipv6 --enable-local \
    --enable-crypt --enable-spasswd --enable-modules --enable-backends \
    --disable-sql --disable-perl \
    --disable-argon2 --disable-wt \
    --enable-overlays=mod --with-cyrus-sasl --with-threads \
    --with-yielding_select=yes \
    ac_cv_func_malloc_0_nonnull=yes \
    ac_cv_func_realloc_0_nonnull=yes \
    ac_cv_func_memcmp_working=yes

  sed -i -e 's/ -shared / -Wl,-O1,--as-needed\0/g' libtool
  make STRIP=armv6-rpi-linux-gnueabihf-strip

  # Neutralize libtool's relink command inside all generated meta files.
  find . -name "*.la" -exec sed -i 's/^relink_command=.*/relink_command=""/g' {} +
}

package_libldap() {
  cd "${srcdir}/${pkgbase}-${pkgver}"
  export PATH="${_toolchain_bin}:$PATH"
  
  make STRIP=armv6-rpi-linux-gnueabihf-strip DESTDIR="${pkgdir}" install
  rm -rf "${pkgdir}"/usr/bin "${pkgdir}"/usr/lib/slapd* "${pkgdir}"/etc "${pkgdir}"/usr/share/man
}

package_openldap() {
  cd "${srcdir}/${pkgbase}-${pkgver}"
  export PATH="${_toolchain_bin}:$PATH"

  make STRIP=armv6-rpi-linux-gnueabihf-strip DESTDIR="${pkgdir}" install
  rm -rf "${pkgdir}"/usr/include "${pkgdir}"/usr/lib/libl* "${pkgdir}"/usr/share/man
  
  install -Dm644 "${srcdir}"/openldap.tmpfiles "${pkgdir}"/usr/lib/tmpfiles.d/openldap.conf
  install -Dm644 "${srcdir}"/openldap.sysusers "${pkgdir}"/usr/lib/sysusers.d/openldap.conf
}