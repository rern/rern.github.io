prepare() {
  # Build inside the extracted release directory instead of the raw git cache directory
  cd "${srcdir}/${pkgname}-${pkgver}"

  export SKIP_PO="1"
  export GNULIB_TOOL_IMPL="sh"
  echo "${pkgver}" > .tarball-version

  git submodule init
  git config submodule.gnulib.url "${srcdir}/gnulib"
  git -c protocol.file.allow=always submodule update

  patch -p1 -i ../nettle-4.patch

  # Force copy missing structural scripts from gnulib landscape directly 
  autoreconf -fiv

  cat >> doc/sample.wgetrc <<EOF

# default root certs location
ca_certificate=/etc/ssl/certs/ca-certificates.crt
EOF
}

build() {
  TOOLCHAIN="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
  SYSROOT="/home/x/x-sysroot"

  # Clean makepkg native host architecture profiles
  unset CFLAGS CXXFLAGS LDFLAGS CPPFLAGS CHOST

  # Setup cross-compilation binaries
  local TARGET_CC="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-gcc"
  local TARGET_CXX="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-g++"
  local TARGET_AR="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ar"
  local TARGET_RANLIB="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ranlib"
  local TARGET_LD="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ld"

  # FIXED: Added -DO_TEXT=0 to bypass windows-specific macro requirements
  local TARGET_CFLAGS="--sysroot=${SYSROOT} -O2 -DO_BINARY=0 -DO_TEXT=0"
  local TARGET_CXXFLAGS="--sysroot=${SYSROOT} -O2"
  local TARGET_CPPFLAGS="--sysroot=${SYSROOT}"
  local TARGET_LDFLAGS="--sysroot=${SYSROOT} -L${SYSROOT}/usr/lib"

  export LTFLAGS="-no-fast-install"
  export AM_LIBTOOLFLAGS="-no-fast-install"

  cd "${srcdir}/${pkgname}-${pkgver}"
  
  ./configure \
    --host=armv6-rpi-linux-gnueabihf \
    --build=$(gcc -dumpmachine) \
    --prefix=/usr \
    --sysconfdir=/etc \
    --disable-rpath \
    --enable-nls \
    --with-ssl=gnutls \
    ac_cv_func_c32width=no \
    ac_cv_func_c32isprint=no \
    ac_cv_func_c32iscntrl=no \
    ac_cv_func_mbszero=no \
    CC="${TARGET_CC}" \
    CXX="${TARGET_CXX}" \
    AR="${TARGET_AR}" \
    RANLIB="${TARGET_RANLIB}" \
    LD="${TARGET_LD}" \
    CFLAGS="${TARGET_CFLAGS}" \
    CXXFLAGS="${TARGET_CXXFLAGS}" \
    CPPFLAGS="${TARGET_CPPFLAGS}" \
    LDFLAGS="${TARGET_LDFLAGS}"

  # Explicitly tell make to skip assembling documentation files completely
  make SUBDIRS="src po"

  # Generate translation files manually using native host utility tools
  cd po
  for po in *.po; do
    msgfmt "${po}" -o "${po%.po}.mo"
  done
}
# Omit check() because target binaries cannot execute on x86_64 host

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  
  # Install binary paths and translations, skipping doc files safely
  make DESTDIR="${pkgdir}" SUBDIRS="src po" install

  # Clear out remaining document layouts if any bypass occurred
  rm -rf "${pkgdir}/usr/share/man"
  rm -rf "${pkgdir}/usr/share/info"

  # Install built translation binaries 
  cd po
  for wget_mo in *.mo; do
    install -Dm 644 "${wget_mo}" "${pkgdir}/usr/share/locale/${wget_mo%.mo}/LC_MESSAGES/${pkgname}.mo"
  done

  for wget_gnulib_mo in *.gmo; do
    install -Dm 644 "${wget_gnulib_mo}" "${pkgdir}/usr/share/locale/${wget_gnulib_mo%.gmo}/LC_MESSAGES/${pkgname}-gnulib.mo"
  done
}