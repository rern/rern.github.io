# Maintainer: Adapted for cross-compilation (armv6h Raspberry Pi Zero)

pkgname=gettext
pkgver=1.0
pkgrel=2
pkgdesc="GNU internationalization runtime libraries (cross-compiled for armv6h)"
url="https://www.gnu.org/software/gettext/"
arch=(armv6h)
license=('GFDL-1.2-only' 'GPL-2.0-only' 'GPL-2.0-or-later' 'LGPL-2.0-only')
depends=(acl attr curl glibc json-c libgcc libgomp libstdc++ gnulib-l10n libunistring libxml2 ncurses sh)
makedepends=()
options=(!docs)
source=(https://ftp.gnu.org/pub/gnu/gettext/${pkgname}-${pkgver}.tar.gz)
sha256sums=('SKIP')

prepare() {
  cd "${pkgname}-${pkgver}"
}

build() {
  cd "${pkgname}-${pkgver}"

  TOOLCHAIN="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
  SYSROOT="/home/x/x-sysroot"

  export CC="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-gcc"
  export CXX="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-g++"
  export AR="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ar"
  export RANLIB="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ranlib"
  export LD="${TOOLCHAIN}/armv6-rpi-linux-gnueabihf-ld"

  export CFLAGS="--sysroot=${SYSROOT} -O2"
  export CXXFLAGS="--sysroot=${SYSROOT} -O2"
  export LDFLAGS="--sysroot=${SYSROOT} -L${SYSROOT}/usr/lib"

  export PKG_CONFIG_SYSROOT_DIR="${SYSROOT}"
  export PKG_CONFIG_PATH="${SYSROOT}/usr/lib/pkgconfig"

  ./configure \
    --host=armv6-rpi-linux-gnueabihf \
    --build=$(gcc -dumpmachine) \
    --prefix=/usr \
    --libexecdir=/usr/lib \
    --sysconfdir=/etc \
    --disable-nls \
    --without-included-gettext \
    --without-included-libunistring \
    --disable-dependency-tracking

  # Only build runtime parts
  make -C gettext-runtime
  make -C gettext-runtime/libasprintf
}

package() {
  cd "${pkgname}-${pkgver}"

  # Install only runtime libraries, skip gettext-tools
  make -C gettext-runtime DESTDIR="${pkgdir}" install
  make -C gettext-runtime/libasprintf DESTDIR="${pkgdir}" install
}
