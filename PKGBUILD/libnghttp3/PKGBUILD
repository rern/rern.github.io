# Maintainer: kpcyrd <kpcyrd[at]archlinux[dot]org>
# Maintainer: Christian Hesse <eworm@archlinux.org>

pkgname=libnghttp3
pkgver=1.16.0
pkgrel=1
pkgdesc='HTTP/3 library written in C (Cross-compiled for armv6h)'
url='https://github.com/ngtcp2/nghttp3'
arch=('armv6h') # Updated for the target architecture
license=('MIT')
depends=('glibc')
makedepends=('git')
provides=('libnghttp3.so')
validpgpkeys=('F4F3B91474D1EB29889BD0EF7E8403D5D673C366')
source=("git+https://github.com/ngtcp2/nghttp3.git?signed#tag=v${pkgver}"
        'git+https://github.com/ngtcp2/munit.git'
        'git+https://github.com/ngtcp2/sfparse.git')
sha256sums=('3eb17b42aae96245755516b49605cb2a19316a97d66f2da5430cd61c872cda87'
            'SKIP'
            'SKIP')

# Set up cross-compilation environment variables
_tc_path="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
_sysroot="/home/x/x-sysroot"
_target="armv6-rpi-linux-gnueabihf"

prepare() {
  cd nghttp3/

  git config --file=.gitmodules submodule.tests/munit.url ../munit/
  git config --file=.gitmodules submodule.lib/sfparse.url ../sfparse/

  git submodule init
  git -c protocol.file.allow=always submodule update

  autoreconf -i
}

build() {
  cd nghttp3/

  # Inject the toolchain path and override compilation tools
  export PATH="${_tc_path}:${PATH}"
  export CC="${_target}-gcc"
  export CXX="${_target}-g++"
  export AR="${_target}-ar"
  export RANLIB="${_target}-ranlib"
  export LD="${_target}-ld"
  
  # Ensure the compiler searches your custom sysroot for dependencies
  export CFLAGS="-O2 -pipe --sysroot=${_sysroot}"
  export CXXFLAGS="-O2 -pipe --sysroot=${_sysroot}"
  export LDFLAGS="--sysroot=${_sysroot}"

  ./configure \
    --prefix=/usr \
    --host="${_target}" \
    --build="x86_64-pc-linux-gnu" \
    --disable-doc \
    --disable-examples \
    --disable-static
  
  make
}

# Omitted check() because the compiled binaries are for ARM and cannot run on x86_64

package() {
  cd nghttp3/

  # Stage into the standard Arch package directory
  make DESTDIR="${pkgdir}" install
  install -D -m0644 COPYING -t "${pkgdir}/usr/share/licenses/${pkgname}"

  # Remove any stray man pages or documentation if generated
  rm -rf "${pkgdir}/usr/share/doc"
  rm -rf "${pkgdir}/usr/share/man"

  # Syncing files cleanly to your local sysroot
  echo "==> Syncing files to local sysroot: ${_sysroot}"
  
  # Ensure target directories exist and are writable by your current user
  mkdir -p "${_sysroot}/usr/include" "${_sysroot}/usr/lib"
  chmod -R u+w "${_sysroot}/usr/include" "${_sysroot}/usr/lib" 2>/dev/null || true

  # Copy headers safely
  if [ -d "${pkgdir}/usr/include" ]; then
    cp -rP "${pkgdir}/usr/include"/* "${_sysroot}/usr/include/"
  fi

  # Copy libraries safely (handling symlinks correctly)
  if [ -d "${pkgdir}/usr/lib" ]; then
    cp -rP "${pkgdir}/usr/lib"/* "${_sysroot}/usr/lib/"
  fi
}