# Maintainer:
# Contributor: Cross-compiled for Arch Linux ARM (armv6h / Raspberry Pi Zero)

pkgname=freetds
pkgver=1.5.18
pkgrel=1
pkgdesc='Library for accessing Sybase and MS SQL Server databases (ARMv6h)'
url='https://www.freetds.org'
arch=(armv6h)
license=(GPL-2.0-only
         LGPL-2.0-only)
depends=(glibc
         krb5
         openssl
         readline
         unixodbc)
backup=(etc/freetds/freetds.conf
        etc/freetds/locales.conf
        etc/freetds/pool.conf)
source=(https://www.freetds.org/files/stable/$pkgname-$pkgver.tar.bz2)
sha256sums=('6b2c8b93b9ee7c83855daf745de5878790032f14dbaee553d83a9d211b84dd4b')

build() {
  # Set compilation and structural target link flags
  export LDFLAGS="-Wl,-fuse-ld=bfd -Wl,-O1,--as-needed --sysroot=${_sysroot}"
  export CFLAGS="-O2 -pipe --sysroot=${_sysroot} -include stddef.h -include stdio.h"
  export CXXFLAGS="-O2 -pipe --sysroot=${_sysroot} -include stddef.h -include stdio.h"
  export CPPFLAGS="-I${_sysroot}/usr/include"

  local _target_triplet="armv6-rpi-linux-gnueabihf"
  local _toolchain_bin="/home/x/x-tools/${_target_triplet}/bin"
  local _sysroot="/home/x/rpi0_sysroot"

  # Map cross-toolchain environment paths
  export PATH="${_toolchain_bin}:${PATH}"
  export CC="${_toolchain_bin}/${_target_triplet}-gcc"
  export CXX="${_toolchain_bin}/${_target_triplet}-g++"
  
  # Point user-space QEMU runner to the sysroot dynamic loader and shared libraries
  export QEMU_LD_PREFIX="${_sysroot}"
  
  # Pin pkg-config allocations to target sysroot configuration libraries 
  export PKG_CONFIG_DIR=""
  export PKG_CONFIG_LIBDIR="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"
  export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"

  # Set compilation and structural target link flags
  export LDFLAGS="-Wl,-fuse-ld=bfd -Wl,-O1,--as-needed --sysroot=${_sysroot}"
  export CFLAGS="-O2 -pipe --sysroot=${_sysroot}"
  export CXXFLAGS="-O2 -pipe --sysroot=${_sysroot}"
  export CPPFLAGS="-I${_sysroot}/usr/include"

  cd "${srcdir}/$pkgname-$pkgver"

  # Pass the explicit sysroot path to bypass host filesystem pollution (-I/usr/include)
cd "${srcdir}/$pkgname-$pkgver"

  # Bypassing odbc_config by feeding variables directly to the preprocessor
  ./configure \
    --host=${_target_triplet} \
    --prefix=/usr \
    --sysconfdir=/etc/freetds \
    --enable-msdblib \
    --enable-krb5 \
    --with-openssl \
    ODBC_CFLAGS="-I${_sysroot}/usr/include" \
    ODBC_LIBS="-L${_sysroot}/usr/lib -lodbc"
        
      sed -i 's/ -shared / -Wl,-O1,--as-needed\0/g' libtool # Avoid overlinking
  make 
}

package() {
  cd "$pkgname-$pkgver"
  make DESTDIR="$pkgdir" install
}