arch=('armv6h')
license=(MPL-2.0)
depends=(glibc nspr p11-kit sh sqlite zlib)
makedepends=(gyp mercurial perl python)
options=('!strip')
source=(
  "hg+https://hg.mozilla.org/projects/nss#tag=NSS_${pkgver//./_}_RTM"
  bundle.sh
  certdata2pem.py
)
b2sums=('d46b789c963fb0ef6fc85dc3477a3cf2baf57fe58338e4460409987203c592df0ad4db2e2245d81ddef1b94169825201797daad99fd994992ade1c9c0bee9c21'
        '4be5dd836c844fdd7b63302a6994d62149082c3bc81eef70f373f416fed80a61a923960e4390d1c391b81ab01b409370d788818a30ffdd3a4ed467b670f990f6'
        '6bb59dcc9289916dcbf8fb6d73db0c0cd7582dc12a3aa4e8be19ec62c9ede65fdd9470a2d92ec5a114506b78d2d21b8ae0a1b45a17dc1f90f7d75434a93da510')

_sysroot="/home/x/x-sysroot"
_toolchain_bin="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"

prepare() {
  mkdir -p certs
  ln -srft certs nss/lib/ckfw/builtins/{certdata.txt,nssckbi.h}

  # Provide empty stubs for ARM32 NEON/GCM symbols to satisfy gcm.c linker dependencies
  echo "void platform_ghash_support(void) {} void gcm_HashInit_hw(void) {} void gcm_HashWrite_hw(void) {} void gcm_HashZeroX_hw(void) {}" > nss/lib/freebl/ghash-arm32-neon.c

  # Provide empty stubs for SHA256 ARMv8 files to satisfy the sha512.c linker dependencies
  echo "void SHA256_Compress_Native(void) {} void SHA256_Update_Native(void) {}" > nss/lib/freebl/sha256-armv8.c

  # Provide empty stubs for SHA1 ARMv8 files to satisfy sha_fast.c linker dependencies
  echo "void SHA1_Compress_Native(void) {} void SHA1_Update_Native(void) {}" > nss/lib/freebl/sha1-armv8.c

  # Provide empty stubs for AES ARMv8 files to satisfy rijndael.c linker dependencies
  cat << EOF > nss/lib/freebl/aes-armv8.c
void arm_aes_decrypt_ecb_128(void) {}
void arm_aes_decrypt_ecb_256(void) {}
void arm_aes_decrypt_ecb_192(void) {}
void arm_aes_encrypt_ecb_128(void) {}
void arm_aes_encrypt_ecb_256(void) {}
void arm_aes_encrypt_ecb_192(void) {}
void arm_aes_decrypt_cbc_128(void) {}
void arm_aes_decrypt_cbc_256(void) {}
void arm_aes_decrypt_cbc_192(void) {}
void arm_aes_encrypt_cbc_128(void) {}
void arm_aes_encrypt_cbc_256(void) {}
void arm_aes_encrypt_cbc_192(void) {}
EOF

  cd nss
}

build() {
  local buildsh_options=(
    --disable-tests
    --enable-libpkix
    --opt
    --system-nspr
    --system-sqlite
    -t arm
  )

  cd certs
  ../certdata2pem.py

  cd ..
  ./bundle.sh

  cd nss

  # Inject your toolchain binaries into environment paths
  export PATH="${_toolchain_bin}:$PATH"
  export CC=armv6-rpi-linux-gnueabihf-gcc
  export CXX=armv6-rpi-linux-gnueabihf-g++
  export AR=armv6-rpi-linux-gnueabihf-ar
  export RANLIB=armv6-rpi-linux-gnueabihf-ranlib
  export STRIP=armv6-rpi-linux-gnueabihf-strip
  
  # Tell GYP to use native host compilers for compiling host code generation utilities
  export CC_host=gcc
  export CXX_host=g++

  # Explicitly disable NEON, ARMv8, and ARM32-NEON extensions to keep compilation pure ARMv6 soft/vfp
  export CFLAGS="-O2 -march=armv6 -mfloat-abi=hard -mfpu=vfp --sysroot=${_sysroot} -DNSS_DISABLE_NEON -DNSS_DISABLE_ARM_NEON -DNSS_DISABLE_ARM32_NEON"
  export CPPFLAGS="--sysroot=${_sysroot} -I${_sysroot}/usr/include"
  export CXXFLAGS="${CFLAGS}"
  export LDFLAGS="-Wl,-O1,--as-needed --sysroot=${_sysroot} -L${_sysroot}/usr/lib"

  # Force pkg-config to parse cross ARM libraries instead of host libraries
  export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"
  export PKG_CONFIG_PATH="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"

  # Force explicit ARMv6 target profiles and explicitly bind FPU to VFP (not NEON)
  export GYP_DEFINES="target_arch=arm arm_version=6 arm_neon=0 arm_fpu=vfp arm_float_abi=hard sign_libs=0"
  
  # Throttle Ninja jobs to keep RAM usage stable
  export NINJAJOBS="-j2"

  ./build.sh "${buildsh_options[@]}"
}

package_nss() {
  export PATH="${_toolchain_bin}:$PATH"
  export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"
  export PKG_CONFIG_PATH="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"

  local nsprver="$(pkg-config --modversion nspr)"
  local libdir=/usr/lib includedir=/usr/include/nss

  sed nss/pkg/pkg-config/nss.pc.in \
    -e "s,%prefix%,/usr,g" \
    -e "s,%exec_prefix%,\${prefix},g" \
    -e "s,%libdir%,$libdir,g" \
    -e "s,%includedir%,$includedir,g" \
    -e "s,%NSPR_VERSION%,$nsprver,g" \
    -e "s,%NSS_VERSION%,$pkgver,g" |
    install -Dm644 /dev/stdin "$pkgdir$libdir/pkgconfig/nss.pc"

  ln -s nss.pc "$pkgdir$libdir/pkgconfig/mozilla-nss.pc"

  install -Dt "$pkgdir$libdir" dist/Release/lib/*.so

  local vmajor vminor vpatch
  { read vmajor; read vminor; read vpatch; } \
    < <(awk '/#define.*NSS_V(MAJOR|MINOR|PATCH)/ {print $3}' nss/lib/nss/nss.h)

  sed nss/pkg/pkg-config/nss-config.in \
    -e "s,@prefix@,/usr,g" \
    -e "s,@exec_prefix@,/usr,g" \
    -e "s,@libdir@,$libdir,g" \
    -e "s,@includedir@,$includedir,g" \
    -e "s,@MOD_MAJOR_VERSION@,$vmajor,g" \
    -e "s,@MOD_MINOR_VERSION@,$vminor,g" \
    -e "s,@MOD_PATCH_VERSION@,$vpatch,g" |
    install -D /dev/stdin "$pkgdir/usr/bin/nss-config"

  install -Dt "$pkgdir/usr/bin" \
    dist/Release/bin/{*util,shlibsign,signtool,signver,ssltap}

  install -Dt "$pkgdir$includedir" -m644 dist/public/nss/*.h

  ln -sf pkcs11/p11-kit-trust.so "$pkgdir$libdir/libnssckbi.so"
}

package_ca-certificates-mozilla() {
  pkgdesc="Mozilla's set of trusted CA certificates"
  depends=('ca-certificates-utils>=20181109-3')

  install -Dm644 ca-bundle.trust.p11-kit \
    "$pkgdir/usr/share/ca-certificates/trust-source/mozilla.trust.p11-kit"
}