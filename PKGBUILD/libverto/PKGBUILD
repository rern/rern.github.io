# Maintainer: Andreas Radke <andyrtr@archlinux.org>
# Contributor: Mantas Mikulėnas <grawity@gmail.com>

pkgname=libverto
pkgver=0.3.2
pkgrel=6
pkgdesc="Main event loop abstraction library"
arch=('armv6h')
url="https://github.com/latchset/libverto"
license=('MIT')
depends=('glibc' 'libevent')
provides=('libverto.so' 'libverto-libevent.so' 'libverto-module-base')
conflicts=("krb5<1.19.3-2" "libverto-libevent<0.3.2-4")
replaces=("libverto-libevent<0.3.2-4")
options=('!strip')

source=("https://github.com/latchset/libverto/releases/download/$pkgver/libverto-$pkgver.tar.gz")
sha256sums=('8d1756fd704f147549f606cd987050fb94b0b1ff621ea6aa4d6bf0b74450468a')

_sysroot="/home/x/x-sysroot"
_toolchain_bin="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"

build() {
  cd "$pkgname-$pkgver"

  export PATH="${_toolchain_bin}:$PATH"
  export CC=armv6-rpi-linux-gnueabihf-gcc
  export LD=armv6-rpi-linux-gnueabihf-ld
  export AR=armv6-rpi-linux-gnueabihf-ar
  export RANLIB=armv6-rpi-linux-gnueabihf-ranlib
  export STRIP=armv6-rpi-linux-gnueabihf-strip

  export CFLAGS="-O2 -march=armv6 -mfloat-abi=hard -mfpu=vfp --sysroot=${_sysroot}"
  export CPPFLAGS="--sysroot=${_sysroot} -I${_sysroot}/usr/include"
  export CXXFLAGS="${CFLAGS}"
  export LDFLAGS="-Wl,-O1,--as-needed --sysroot=${_sysroot} -L${_sysroot}/usr/lib"

  export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"
  export PKG_CONFIG_PATH="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"

  ./configure \
    --host=armv6-rpi-linux-gnueabihf \
    --prefix=/usr \
    --disable-static \
    --with-libevent \
    --without-libev \
    --without-glib

  make STRIP=armv6-rpi-linux-gnueabihf-strip

  # Neutralize libtool's relink command to prevent x86_64 host contamination
  find . -name "*.la" -exec sed -i 's/^relink_command=.*/relink_command=""/g' {} +
}

# Disabled: Cannot run ARM binaries natively on the x86_64 host environment
# check() {
#   cd "$pkgname-$pkgver"
#   make check
# }

package_libverto() {
  cd "$pkgname-$pkgver"
  export PATH="${_toolchain_bin}:$PATH"

  make STRIP=armv6-rpi-linux-gnueabihf-strip DESTDIR="$pkgdir" install

  install -Dm0644 COPYING -t "$pkgdir/usr/share/licenses/$pkgname"
}