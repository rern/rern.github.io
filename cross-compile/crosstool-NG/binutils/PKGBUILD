# Maintainer: You

pkgname=binutils
pkgver=2.46+r70+g155188ea10a7
_commit=155188ea10a78d18416b8c0f62e17da66d8385a7
pkgrel=1
pkgdesc='GNU binutils cross-compiled for Raspberry Pi Zero (ARMv6h)'
arch=(armv6h)
url='https://www.gnu.org/software/binutils/'
license=(GPL-2.0-or-later GPL-3.0-or-later LGPL-2.0-or-later LGPL-3.0-or-later GFDL-1.3 FSFAP)

depends=(glibc jansson libelf zlib zstd)
makedepends=(git)
checkdepends=(bc dejagnu)

source=(
  git+https://sourceware.org/git/binutils-gdb.git#commit=${_commit}
  gold-warn-unsupported.patch
  0001-strip-Don-t-treat-fat-IR-objects-as-plugin-object.patch
)
sha256sums=('471831d95080719823e948806d11867be0de797f4a2f72e8c766bd52f18b9d95'
            '2d430b66f84a19c154725ec535280c493be1d34f1a90f95208dce02fecd0e4e4'
            'cd1816becb0e992ebc09f2ff66050e4b92fad33f0b7acc833cf513f4e4791d1a')

prepare() {
  mkdir -p binutils-build
  cd binutils-gdb
  sed -i '/^development=/s/true/false/' bfd/development.sh
  patch -Np1 < ../gold-warn-unsupported.patch
}

build() {
  cd binutils-build

  TOOLCHAIN=/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin
  SYSROOT=/home/x/rpi0_sysroot

  export PATH=$TOOLCHAIN:$PATH
  export CC=armv6-rpi-linux-gnueabihf-gcc
  export AR=armv6-rpi-linux-gnueabihf-ar
  export LD=armv6-rpi-linux-gnueabihf-ld

  # Override Arch’s host flags with ARMv6-appropriate ones
  export CFLAGS="-O2 -march=armv6 -mfpu=vfp -mfloat-abi=hard"
  export CXXFLAGS="$CFLAGS"
  export LDFLAGS=""

  CONFIGFLAG="--host=armv6-rpi-linux-gnueabihf --build=x86_64-pc-linux-gnu --target=armv6-rpi-linux-gnueabihf"

  "${srcdir}"/binutils-gdb/configure \
    --prefix=/usr \
    --sysconfdir=/etc \
    --with-sysroot=$SYSROOT \
    --with-lib-path=/usr/lib:/usr/local/lib \
    --enable-gold \
    --enable-ld=default \
    --enable-plugins \
    --enable-shared \
    --disable-gdb \
    --disable-gdbserver \
    --disable-sim \
    --disable-werror \
    $CONFIGFLAG

  make -O tooldir=/usr
}

check() {
  cd binutils-build
  # Optional: disable tests for cross builds, or run with emulator
  true
}

package() {
  cd binutils-build

  export lt_cv_sys_lib_search_path_spec="$SYSROOT/usr/lib"
  export lt_cv_sys_lib_dlsearch_path_spec="$SYSROOT/usr/lib"
  export LIBRARY_PATH=$SYSROOT/usr/lib
  export C_INCLUDE_PATH=$SYSROOT/usr/include
  export CPLUS_INCLUDE_PATH=$SYSROOT/usr/include

  make DESTDIR="${pkgdir}" install-strip || true

  install -m644 libiberty/pic/libiberty.a "${pkgdir}"/usr/lib
  rm -f "${pkgdir}"/usr/share/man/man1/{dlltool,windres,windmc}*
  rm -f "${pkgdir}"/usr/lib/lib{bfd,opcodes}.so
}
