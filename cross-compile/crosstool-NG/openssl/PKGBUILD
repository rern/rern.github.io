# Maintainer: Pierre Schmitz <pierre@archlinux.de>
# ALARM: Kevin Mihelich <kevin@archlinuxarm.org>
#   - set ARM architecture targets
# Cross-compiled for armv6h (Raspberry Pi 0/1) via crosstool-ng

pkgname=openssl
pkgver=3.6.3
pkgrel=1
pkgdesc='The Open Source toolkit for cryptography and Transport Layer Security (Cross-compiled for armv6h)'
arch=('armv6h')
url='https://www.openssl.org'
license=('Apache-2.0')
depends=('brotli' 'glibc' 'zlib' 'zstd')
makedepends=('perl')
optdepends=('ca-certificates' 'perl')
replaces=('openssl-perl' 'openssl-doc')
provides=('libcrypto.so' 'libssl.so')
backup=('etc/ssl/openssl.cnf')
source=("https://github.com/${pkgname}/${pkgname}/releases/download/${pkgname}-${pkgver}/${pkgname}-${pkgver}.tar.gz"{,.asc}
        'ca-dir.patch')
sha256sums=('243a86649cf6f23eeb6a2ff2456e09e5d77dd9018a54d3d96b0c6bdd6ba6c7f1'
            'SKIP'
            '0a32d9ca68e8d985ce0bfef6a4c20b46675e06178cc2d0bf6d91bd6865d648b7')
validpgpkeys=('EFC0A467D613CB83C7ED6D30D894E2CE8B3D79F5'
              'BA5473A2B0587B07FB27CF2D216094DFD0CB81EF')

# --- Cross-Compiling Variables ---
_sysroot="/home/x/rpi0_sysroot"
_toolchain_bin="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
_triple="armv6-rpi-linux-gnueabihf"

prepare() {
    cd "$srcdir/$pkgname-$pkgver"

    # set ca dir to /etc/ssl by default
    patch -Np1 -i "$srcdir/ca-dir.patch"
}

build() {
    cd "$srcdir/$pkgname-$pkgver"

    # Export cross-compilation environment
    export PATH="${_toolchain_bin}:${PATH}"
    export CC="${_triple}-gcc"
    export CXX="${_triple}-g++"
    export AR="${_triple}-ar"
    export RANLIB="${_triple}-ranlib"
    
    # Ensure pkg-config looks inside the sysroot for dependencies (zlib, zstd, etc.)
    export PKG_CONFIG_DIR=""
    export PKG_CONFIG_LIBDIR="${_sysroot}/usr/lib/pkgconfig:${_sysroot}/usr/share/pkgconfig"
    export PKG_CONFIG_SYSROOT_DIR="${_sysroot}"

    # Force compiler to look into the sysroot
    export CFLAGS="-O2 -pipe --sysroot=${_sysroot}"
    export CXXFLAGS="-O2 -pipe --sysroot=${_sysroot}"
    export LDFLAGS="-Wl,-O1,--sort-common,--as-needed,-z,relro,-z,now --sysroot=${_sysroot}"

    # OpenSSL maps armv6/armv7 to the 'linux-armv4' target config
    local openssltarget='linux-armv4'
    local optflags=''

    ./Configure --prefix=/usr --openssldir=/etc/ssl --libdir=lib \
        shared enable-ktls enable-brotli enable-zlib enable-zstd \
        ${optflags} "${openssltarget}"

    make depend
    make
}

# Disabled because host (x86_64) cannot execute target (armv6h) binaries without QEMU binfmt
check() {
    echo "Skipping checks during cross-compilation."
}

package() {
    cd "$srcdir/$pkgname-$pkgver"

    make DESTDIR="$pkgdir" MANDIR=/usr/share/man MANSUFFIX=ssl install_sw install_ssldirs install_man_docs

    chmod 700 "$pkgdir/etc/ssl/private"

    install -D -m644 LICENSE.txt "$pkgdir/usr/share/licenses/$pkgname/LICENSE.txt"
}