pkgver() {
  cd glibc
  git describe --abbrev=12 --tags | sed 's/[^-]*-//;s/[^-]*-/&r/;s/-/+/g'
}

prepare() {
  mkdir -p glibc-build

  [[ -d glibc-$pkgver ]] && ln -s glibc-$pkgver glibc
  cd glibc
  patch -Np1 < ../0001-include-isolate-__O_CLOEXEC-flag-for-sys-mount.h-and.patch
  patch -Np1 < ../0002-Linux-Only-define-OPEN_TREE_-macros-in-sys-mount.h-i.patch
  patch -Np1 < ../0001-resolv-Check-for-inet_ntop-failure-in-ns_sprintrrf.patch
  patch -Np1 < ../0002-resolv-Remove-incorrect-parts-of-TSIG-handling-from-.patch
  patch -Np1 < ../0003-resolv-Fix-buffer-overreads-in-ns_sprintrrf-CVE-2026.patch
  patch -Np1 < ../0004-resolv-Add-test-case-tst-ns_sprintrr-bug-34033-bug-3.patch
}

build() {
  # Setup cross-compiler environment
  export PATH="${_cross_toolchain}:${PATH}"
  export CC="${_target_triple}-gcc"
  export CXX="${_target_triple}-g++"
  export AR="${_target_triple}-ar"
  export RANLIB="${_target_triple}-ranlib"
  export STRIP="${_target_triple}-strip"

  # Enforce architecture flags for RPi Zero (ARMv6zk + VFP)
  export CFLAGS="-O2 -pipe -march=armv6zk -mcpu=arm1176jzf-s -mfpu=vfp -mfloat-abi=hard"
  export CXXFLAGS="${CFLAGS}"

  local _configure_flags=(
      --prefix=/usr
      --with-headers="${_cross_sysroot}/usr/include"
      --with-bugurl=https://github.com/archlinuxarm/PKGBUILDs/issues
      --enable-bind-now
      --enable-fortify-source
      --disable-multi-arch
      --enable-stack-protector=strong
      --disable-systemtap # Disabled unless you have cross-systemtap headers
      --disable-nscd
      --disable-profile
      --disable-werror
      --host=${_target_triple}
      --build=x86_64-pc-linux-gnu
  )

  # _FORTIFY_SOURCE=3 mitigation
  CFLAGS=${CFLAGS/-Wp,-D_FORTIFY_SOURCE=3/}
  CFLAGS=${CFLAGS/-fno-plt/}

  (
    cd glibc-build

    echo "slibdir=/usr/lib" >> configparms
    echo "rtlddir=/usr/lib" >> configparms
    echo "sbindir=/usr/bin" >> configparms
    echo "rootsbindir=/usr/bin" >> configparms

    # Force the localedef binary built for the host during cross-compilation
    echo "cross-compiling = yes" >> configparms

    "${srcdir}"/glibc/configure \
        --libdir=/usr/lib \
        --libexecdir=/usr/lib \
        "${_configure_flags[@]}"

    make -O
    make info
  )

  # Localedef cannot be executed natively during a cross-build unless using a host binary.
  # We skip pregenerating target locales via cross-compiled localedef.
}

check() {
  # Cross-compiled binaries cannot be tested natively on x86_64
  echo "Skipping testsuite due to cross-compilation."
}

package_glibc() {
  pkgdesc='GNU C Library (ARMv6h Cross-compiled)'
  depends=('linux-api-headers>=4.10' tzdata filesystem)
  optdepends=('gd: for memusagestat'
              'perl: for mtrace')
  install=glibc.install
  backup=(etc/gai.conf
          etc/locale.gen)

  # Run make install using target parameters
  make -C glibc-build DESTDIR="${pkgdir}" install
  rm -f "${pkgdir}"/etc/ld.so.cache
  rm -f "${pkgdir}"/usr/bin/{tzselect,zdump,zic}

  cd glibc
  install -dm755 "${pkgdir}"/usr/lib/locale
  install -m644 posix/gai.conf "${pkgdir}"/etc/gai.conf
  install -m755 "${srcdir}"/locale-gen "${pkgdir}"/usr/bin

  install -m644 "${srcdir}"/locale.gen.txt "${pkgdir}"/etc/locale.gen
  sed -e '1,3d' -e 's|/| |g' -e 's|\\| |g' -e 's|^|#|g' \
    localedata/SUPPORTED >> "${pkgdir}"/etc/locale.gen

  sed -e '1,3d' -e 's|/| |g' -e 's| \\||g' \
    localedata/SUPPORTED > "${pkgdir}"/usr/share/i18n/SUPPORTED

  # Manually create basic fallbacks if full locales-package generation was skipped
  install -dm755 "${pkgdir}"/usr/lib/locale
  install -Dm644 "${srcdir}"/sdt.h "${pkgdir}"/usr/include/sys/sdt.h
  install -Dm644 "${srcdir}"/sdt-config.h "${pkgdir}"/usr/include/sys/sdt-config.h

  # Explicitly strip target binaries using cross-strip tools
  find "${pkgdir}"/usr/bin "${pkgdir}"/usr/lib -type f \( -name "*.so*" -o -executable \) -exec "${_cross_toolchain}/${_target_triple}-strip" --strip-unneeded {} + 2>/dev/null || true
}

package_glibc-locales() {
  pkgdesc='Pregenerated locales for GNU C Library (Stub for cross-build)'
  depends=("glibc=$pkgver")
  
  # Stubbed out because compiling cross-locales relies heavily on a 
  # native host-running localedef matching the exact glibc micro-version.
  mkdir -p "${pkgdir}"/usr/lib/locale
}