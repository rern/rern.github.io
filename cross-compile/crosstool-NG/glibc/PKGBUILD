# Cross-compiling configuration for armv6h (Raspberry Pi Zero)
_cross_toolchain="/home/x/x-tools/armv6-rpi-linux-gnueabihf/bin"
_cross_sysroot="/home/x/rpi0_sysroot"
_target_triple="armv6-rpi-linux-gnueabihf"

noautobuild=1

pkgbase=glibc
pkgname=(glibc glibc-locales)
pkgver=2.43+r22+g8362e8ce10b2
_commit=8362e8ce10b24068bacc19552c128dd10e082fd9
pkgrel=2
arch=(armv6h) # Modified target architecture
url='https://www.gnu.org/software/libc'
license=(GPL-2.0-or-later LGPL-2.1-or-later)
makedepends=(
  gd
  git
  python
)
options=(staticlibs !lto !distcc !strip) # Disable stripping on host, makepkg will fail with x86 strip
source=(
  "git+https://sourceware.org/git/glibc.git#commit=${_commit}"
  locale.gen.txt
  locale-gen
  sdt.h
  sdt-config.h
  0001-include-isolate-__O_CLOEXEC-flag-for-sys-mount.h-and.patch
  0002-Linux-Only-define-OPEN_TREE_-macros-in-sys-mount.h-i.patch
  0001-Linux-Only-define-OPEN_TREE_-macros-in-sys-mount.h-i.patch
  0001-resolv-Check-for-inet_ntop-failure-in-ns_sprintrrf.patch
  0002-resolv-Remove-incorrect-parts-of-TSIG-handling-from-.patch
  0003-resolv-Fix-buffer-overreads-in-ns_sprintrrf-CVE-2026.patch
  0004-resolv-Add-test-case-tst-ns_sprintrr-bug-34033-bug-3.patch
)
