# Cross-compile targeted environment for Raspberry Pi Zero (ARMv6h) via crosstool-NG
noautobuild=1

pkgname=(
  gcc
  gcc-libs
  libatomic
  libgcc
  libgomp
  libitm
  libstdc++
)
pkgver=16.1.1+r12+g301eb08fa2c5
_commit=301eb08fa2c5b6f3045260bf1294c2e2bacbcd90
pkgrel=1
pkgdesc='The GNU Compiler Collection (Cross-compiled native for ARMv6h Pi Zero)'
arch=(armv6h)
CARCH="armv6h"
CHOST="armv6-rpi-linux-gnueabihf"
license=(
  'GPL-3.0-or-later WITH GCC-exception-3.1'
  GFDL-1.3-or-later
)
url='https://gcc.gnu.org'
makedepends=(
  binutils
  doxygen
  git
  libisl
  libmpc
  python
  zstd
)
checkdepends=(
  dejagnu
  expect
  inetutils
  python-pytest
  tcl
)
options=(
  !emptydirs
  !lto
  !distcc
  !strip
  !zipman
  !buildflags
)
_libdir=usr/lib/gcc/$CHOST/${pkgver%%+*}
source=(git+https://sourceware.org/git/gcc.git#commit=$_commit
        c89 c99
        gcc-ada-repro.patch
)
sha256sums=('e7641bfddebaada298ca0a631183ef8d81bb3c5dfd3aef30bc7d4223f1c0e450'
            '7b09ec947f90b98315397af675369a1e3dfc527fa70013062e6e85c4be0275ab'
            '44ea973558842f3f4bd666bdaf6e810fd7b7c7bd36b5cc4c69f93d2cd0124fc7'
            '1773f5137f08ac1f48f0f7297e324d5d868d55201c03068670ee4602babdef2f')

pkgver() {
  cd gcc
  echo "$(cat gcc/BASE-VER)+$(git describe --abbrev=12 --tags | sed 's/[^-]*-[^-]*-//;s/[^-]*-/r&/;s/-/+/g;s/_/./')"
}

prepare() {
  [[ ! -d gcc ]] && ln -s gcc-${pkgver/+/-} gcc
  cd gcc

  # Arch Linux installs x86_64 libraries /lib
  sed -i '/m64=/s/lib64/lib/' gcc/config/i386/t-linux64

  # Arch Linux ARM installs aarch64 libraries /lib
  sed -i '/lp64=/s/lib64/lib/' gcc/config/aarch64/t-aarch64-linux

  # Target configuration switches based on CARCH
  if [[ $CARCH == "armv6h" ]]; then
    CONFIGFLAG="--host=armv6-rpi-linux-gnueabihf --build=x86_64-pc-linux-gnu --target=armv6-rpi-linux-gnueabihf --with-arch=armv6 --with-float=hard --with-fpu=vfp"
  fi

  mkdir -p "$srcdir/gcc-build"
}

build() {
  local _confflags=(
      --build=x86_64-pc-linux-gnu
      --host=armv6-rpi-linux-gnueabihf
      --target=armv6-rpi-linux-gnueabihf
      --with-sysroot=$HOME/x-tools/armv6-rpi-linux-gnueabihf/armv6-rpi-linux-gnueabihf/sysroot
      --prefix=/usr
      --libdir=/usr/lib
      --libexecdir=/usr/lib
      --without-system-zlib
      --disable-bootstrap
      --disable-multilib
      --disable-werror
      --disable-libsanitizer
      --enable-languages=c,c++
      $CONFIGFLAG
  )

  export PATH="$HOME/x-tools/armv6-rpi-linux-gnueabihf/bin:$PATH"

  cd gcc-build
  "$srcdir/gcc/configure" "${_confflags[@]}"
  
  make
}

check() {
  echo 'Skip check()'
}

_deploy_staging_tree() {
  local _staging_dir="$srcdir/gcc-staging-image"
  if [ ! -d "$_staging_dir" ]; then
    msg2 "Installing full GCC suite into staging folder..."
    cd "$srcdir/gcc-build"
    
    export LIBRARY_PATH=""
    export LD_LIBRARY_PATH=""
    
    make \
      DESTDIR="$_staging_dir" \
      LDFLAGS="-Wl,-rpath-link,$HOME/x-tools/armv6-rpi-linux-gnueabihf/armv6-rpi-linux-gnueabihf/sysroot/usr/lib --sysroot=$HOME/x-tools/armv6-rpi-linux-gnueabihf/armv6-rpi-linux-gnueabihf/sysroot" \
      install
  fi
}

_install_runtime_library_exception() {
  install -Dm644 "$srcdir/gcc/COPYING.RUNTIME" \
    "$pkgdir/usr/share/licenses/$pkgname/RUNTIME.LIBRARY.EXCEPTION"
}

_copy_target_lib() {
  local _libname="$1"
  local _staging_dir="$srcdir/gcc-staging-image"
  
  install -dm755 "$pkgdir/usr/lib"
  
  local _found_lib=$(find "$_staging_dir" -name "${_libname}.so*" -print -quit)
  
  if [ -n "$_found_lib" ]; then
    local _lib_dir=$(dirname "$_found_lib")
    cp -a "$_lib_dir"/${_libname}.so* "$pkgdir/usr/lib/"
  else
    error "Could not find ${_libname}.so inside staging tree!"
    return 1
  fi
}

package_gcc() {
  pkgdesc="The GNU Compiler Collection - C and C++ frontends"
  depends=('binutils>=2.28' 'glibc>=2.27' gmp libmpc mpfr)
  options=(!emptydirs staticlibs !strip)

  _deploy_staging_tree
  local _staging_dir="$srcdir/gcc-staging-image"

  install -dm755 "$pkgdir/usr/bin"
  install -dm755 "$pkgdir/usr/lib"
  install -dm755 "$pkgdir/usr/include"

  cp -a "$_staging_dir"/usr/bin/{gcc,g++,c++,cpp,gcov}* "$pkgdir/usr/bin/" || true
  
  if [ -d "$_staging_dir/usr/lib/gcc" ]; then
    cp -a "$_staging_dir"/usr/lib/gcc "$pkgdir/usr/lib/"
  fi
  
  if [ -d "$_staging_dir/usr/include/c++" ]; then
    cp -a "$_staging_dir"/usr/include/c++ "$pkgdir/usr/include/"
  fi

  ln -s gcc "$pkgdir/usr/bin/cc"
  
  for binary in gcc g++; do
    if [ -f "$pkgdir/usr/bin/$binary" ]; then
      ln -s $binary "$pkgdir/usr/bin/armv6-rpi-linux-gnueabihf-$binary"
    fi
  done

  _install_runtime_library_exception
}

package_gcc-libs() {
  pkgdesc='Runtime libraries shipped by GCC'
  depends=('glibc>=2.27' libatomic libgcc libgomp libitm libstdc++)
}

package_libatomic() {
  pkgdesc='GNU Atomic library shipped by GCC'
  depends=('glibc>=2.27')
  provides=(libatomic.so)

  _deploy_staging_tree
  _copy_target_lib "libatomic"
  _install_runtime_library_exception
}

package_libgcc() {
  pkgdesc='Low-level runtime library shipped by GCC'
  depends=('glibc>=2.27')
  provides=(libgcc_s.so)

  _deploy_staging_tree
  _copy_target_lib "libgcc_s"
  _install_runtime_library_exception
}

package_libgomp() {
  pkgdesc='OpenMP library shipped by GCC'
  depends=('glibc>=2.27')
  provides=(libgomp.so)

  _deploy_staging_tree
  _copy_target_lib "libgomp"
  _install_runtime_library_exception
}

package_libitm() {
  pkgdesc='GNU Transactional Memory library shipped by GCC'
  depends=('glibc>=2.27' libgcc)
  provides=(libitm.so)

  _deploy_staging_tree
  _copy_target_lib "libitm"
  _install_runtime_library_exception
}

package_libstdc++ () {
  pkgdesc='C++ runtime libraries shipped by GCC'
  depends=('glibc>=2.27' libgcc)
  provides=(libstdc++.so)

  _deploy_staging_tree
  _copy_target_lib "libstdc++"
  _install_runtime_library_exception
}
